@page
@model IndexModel
@{
    ViewData["Title"] = "Настройки на Профила";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<div class="manage-content p-4 p-md-5 rounded-4 border border-white border-opacity-10 bg-halloween-card shadow-lg position-relative overflow-hidden">
    <div class="spider-web"></div>

    <div class="position-relative z-2">
        <h2 class="text-white fw-black mb-1">
            <i class="bi bi-ghost text-orange me-2"></i> @ViewData["Title"]
        </h2>
        <p class="text-muted mb-4 small text-uppercase ls-2">Управлявайте вашата идентичност</p>

        <partial name="_StatusMessage" for="StatusMessage" />

        <div class="row g-5">
            <div class="col-xl-7">
                <form id="profile-form" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger bg-danger bg-opacity-10 border-danger text-danger border-0 rounded-4 px-4 py-3 mb-4" role="alert"></div>

                    <div class="form-group mb-4">
                        <label asp-for="Input.NewUsername" class="label-halloween">Потребителско име</label>
                        <div class="input-group-halloween">
                            <i class="bi bi-person-circle icon-lead"></i>
                            @* Променено на Input.NewUsername и премахнат 'disabled' *@
                            <input asp-for="Input.NewUsername" class="form-control-halloween" placeholder="Въведете вашето потребителско име" />
                        </div>
                        <span asp-validation-for="Input.NewUsername" class="text-danger-blood small mt-2 d-block"></span>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="Input.PhoneNumber" class="label-halloween">Линия за връзка (Телефон)</label>
                        <div class="input-group-halloween">
                            <i class="bi bi-telephone-fill icon-lead text-orange"></i>
                            <input asp-for="Input.PhoneNumber" class="form-control-halloween" placeholder="Въведете вашия телефонен номер" />
                        </div>
                        <span asp-validation-for="Input.PhoneNumber" class="text-danger-blood small mt-2 d-block"></span>
                    </div>

                    <div class="mt-5 d-flex flex-wrap align-items-center gap-4">
                        <button id="update-profile-button" type="submit" class="btn btn-halloween-lg shadow-orange">
                            ЗАПАЗИ ПРОМЕНИТЕ <i class="bi bi-moon-stars-fill ms-2"></i>
                        </button>
                    </div>
                </form>
            </div>

            <div class="col-xl-5 d-none d-xl-flex flex-column align-items-center justify-content-center text-center">
                <div class="blob-portal mb-4">
                    <i class="bi bi-incognito text-white display-2"></i>
                </div>
                <div class="p-3 border-start border-orange border-2">
                    <h5 class="text-white fw-bold mb-1">Пазете се!</h5>
                    <p class="text-muted small mb-0">Вашите данни са защитени от древни заклинания и модерно криптиране.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --theme-orange: #ff851b;
        --blood-red: #8a0303;
        --witch-purple: #6f42c1;
        --dark-void: #0d0d0d;
        --ls-2: 2px;
    }

    .fw-black {
        font-weight: 900;
    }

    .ls-2 {
        letter-spacing: var(--ls-2);
    }

    /* Дизайн на картата */
    .bg-halloween-card {
        background: linear-gradient(145deg, #1a1a1a 0%, #0a0a0a 100%);
        box-shadow: 0 20px 50px rgba(0,0,0,0.5);
    }

    /* Инпути в Хелоуин стил */
    .label-halloween {
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        color: var(--theme-orange);
        margin-bottom: 10px;
        display: block;
        letter-spacing: 1px;
    }

    .input-group-halloween {
        position: relative;
        display: flex;
        align-items: center;
    }

    .form-control-halloween {
        background: rgba(255, 255, 255, 0.03) !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        color: white !important;
        padding: 15px 15px 15px 50px !important;
        border-radius: 12px !important;
        width: 100%;
        transition: 0.4s;
    }

        .form-control-halloween:focus {
            border-color: var(--theme-orange) !important;
            background: rgba(255, 133, 27, 0.05) !important;
            box-shadow: 0 0 20px rgba(255, 133, 27, 0.1) !important;
            outline: none;
        }

    .icon-lead {
        position: absolute;
        left: 18px;
        font-size: 1.2rem;
        z-index: 5;
    }

    /* Основен стил на бутона */
    .btn-halloween-lg {
        background: var(--theme-orange);
        color: #000 !important; /* Текстът да е черен по подразбиране върху оранжевото */
        border: none;
        padding: 16px 40px;
        border-radius: 50px;
        font-weight: 900;
        text-transform: uppercase;
        transition: 0.3s;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

        /* Стил при посочване (Hover) */
        .btn-halloween-lg:hover {
            background-color: #ffffff; /* Бутонът става бял */
            color: #000000 !important; /* Текстът СТАВА ЧЕРЕН, за да се вижда на белия фон */
            transform: translateY(-3px);
            box-shadow: 0 10px 30px rgba(255, 133, 27, 0.4);
        }

    .shadow-orange {
        box-shadow: 0 0 15px rgba(255, 133, 27, 0.2);
    }

    /* Линк за отказ */
    .link-cancel {
        color: #666;
        text-decoration: none;
        font-weight: 600;
        transition: 0.3s;
    }

        .link-cancel:hover {
            color: white;
        }

    /* Декорации */
    .spider-web {
        position: absolute;
        top: -20px;
        right: -20px;
        width: 150px;
        height: 150px;
        background-image: radial-gradient(circle, transparent 30%, rgba(255,255,255,0.05) 31%, transparent 32%);
        background-size: 20px 20px;
        opacity: 0.3;
        pointer-events: none;
    }

    .blob-portal {
        width: 180px;
        height: 180px;
        background: rgba(111, 66, 193, 0.1);
        border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%;
        display: flex;
        align-items: center;
        justify-content: center;
        animation: portalMorph 10s ease-in-out infinite;
        border: 1px solid rgba(111, 66, 193, 0.2);
    }

    @@keyframes portalMorph {
        0%, 100% {
            border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%;
        }

        50% {
            border-radius: 70% 30% 30% 70% / 70% 70% 30% 30%;
        }
    }

    .text-danger-blood {
        color: #ff4d4d;
        font-weight: 600;
    }

    .text-muted-dark {
        color: #444;
        font-size: 0.8rem;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}