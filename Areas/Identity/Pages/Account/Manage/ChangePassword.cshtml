@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Смяна на парола";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<div class="manage-content p-4 p-md-5 rounded-4 border border-white border-opacity-10 bg-halloween-card shadow-lg position-relative overflow-hidden">
    <div class="ghostly-glow"></div>

    <div class="position-relative z-2">
        <h2 class="text-white fw-black mb-1">
            <i class="bi bi-key-fill text-orange me-2"></i> @ViewData["Title"]
        </h2>
        <p class="text-muted mb-4 small text-uppercase ls-2">Променете вашия таен шифър за достъп</p>

        <partial name="_StatusMessage" for="StatusMessage" />

        <div class="row g-5">
            <div class="col-xl-7">
                <form id="change-password-form" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger bg-danger bg-opacity-10 border-danger text-danger border-0 rounded-4 px-4 py-3 mb-4" role="alert"></div>

                    <div class="form-group mb-4">
                        <label asp-for="Input.OldPassword" class="label-halloween">Настояща парола</label>
                        <div class="input-group-halloween">
                            <i class="bi bi-unlock icon-lead"></i>
                            <input asp-for="Input.OldPassword" class="form-control-halloween" autocomplete="current-password" placeholder="Въведете старата парола" />
                        </div>
                        <span asp-validation-for="Input.OldPassword" class="text-danger-blood small mt-2 d-block"></span>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="Input.NewPassword" class="label-halloween">Нова парола</label>
                        <div class="input-group-halloween">
                            <i class="bi bi-lock-fill icon-lead text-orange"></i>
                            <input asp-for="Input.NewPassword" class="form-control-halloween" autocomplete="new-password" placeholder="Въведете новата парола" />
                        </div>
                        <span asp-validation-for="Input.NewPassword" class="text-danger-blood small mt-2 d-block"></span>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="Input.ConfirmPassword" class="label-halloween">Потвърдете паролата</label>
                        <div class="input-group-halloween">
                            <i class="bi bi-shield-lock-fill icon-lead text-orange"></i>
                            <input asp-for="Input.ConfirmPassword" class="form-control-halloween" autocomplete="new-password" placeholder="Потвърдете новата парола" />
                        </div>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger-blood small mt-2 d-block"></span>
                    </div>

                    <div class="mt-5 d-flex flex-wrap align-items-center gap-4">
                        <button type="submit" class="btn btn-halloween-lg shadow-orange">
                            ОБНОВИ ПАРОЛАТА <i class="bi bi-magic ms-2"></i>
                        </button>
                        <a asp-page="./Index" class="link-cancel">
                            Отказ
                        </a>
                    </div>
                </form>
            </div>

            <div class="col-xl-5 d-none d-xl-flex flex-column align-items-center justify-content-center text-center">
                <div class="lock-icon-wrapper mb-4">
                    <i class="bi bi-safe2 text-white display-1"></i>
                </div>
                <div class="p-3 border-end border-orange border-2 text-end">
                    <h5 class="text-white fw-bold mb-1">Сигурността е вечна</h5>
                    <p class="text-muted small mb-0">Силната парола ви държи далеч от лапите на дигиталните чудовища.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --theme-orange: #ff851b;
        --blood-red: #8a0303;
        --dark-card: #151515;
    }

    .fw-black {
        font-weight: 900;
    }

    .ls-2 {
        letter-spacing: 2px;
    }

    /* Карта */
    .bg-halloween-card {
        background: linear-gradient(145deg, #1a1a1a 0%, #0a0a0a 100%);
        box-shadow: 0 20px 50px rgba(0,0,0,0.6);
    }

    /* Инпути */
    .label-halloween {
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        color: var(--theme-orange);
        margin-bottom: 10px;
        display: block;
    }

    .input-group-halloween {
        position: relative;
        display: flex;
        align-items: center;
    }

    .form-control-halloween {
        background: rgba(255, 255, 255, 0.03) !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        color: white !important;
        padding: 15px 15px 15px 50px !important;
        border-radius: 12px !important;
        width: 100%;
        transition: 0.4s;
    }

        .form-control-halloween:focus {
            border-color: var(--theme-orange) !important;
            background: rgba(255, 133, 27, 0.05) !important;
            box-shadow: 0 0 20px rgba(255, 133, 27, 0.1) !important;
            outline: none;
        }

    .icon-lead {
        position: absolute;
        left: 18px;
        font-size: 1.2rem;
        z-index: 5;
        color: #666;
    }

    /* Бутон */
    /* Основен стил на бутона */
    .btn-halloween-lg {
        background: var(--theme-orange);
        color: #000 !important; /* Текстът да е черен по подразбиране върху оранжевото */
        border: none;
        padding: 16px 40px;
        border-radius: 50px;
        font-weight: 900;
        text-transform: uppercase;
        transition: 0.3s;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

        /* Стил при посочване (Hover) */
        .btn-halloween-lg:hover {
            background-color: #ffffff; /* Бутонът става бял */
            color: #000000 !important; /* Текстът СТАВА ЧЕРЕН, за да се вижда на белия фон */
            transform: translateY(-3px);
            box-shadow: 0 10px 30px rgba(255, 133, 27, 0.4);
        }

    .link-cancel {
        color: #666;
        text-decoration: none;
        font-weight: 600;
    }

        .link-cancel:hover {
            color: white;
        }

    /* Декоративни ефекти */
    .ghostly-glow {
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle, rgba(255, 133, 27, 0.03) 0%, transparent 50%);
        pointer-events: none;
        z-index: 1;
    }

    .lock-icon-wrapper {
        width: 150px;
        height: 150px;
        background: rgba(255, 255, 255, 0.02);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .text-danger-blood {
        color: #ff4d4d;
        font-weight: 600;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}