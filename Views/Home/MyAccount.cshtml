@{
    ViewData["Title"] = "Моят Профил";
    var roles = ViewBag.Roles as IList<string>;
    var roleColor = roles.Contains("Administrator") ? "text-danger" : "text-success"; // Червено за Админ, Зелено за Клиент
    var roleIcon = roles.Contains("Administrator") ? "bi-shield-lock" : "bi-person-badge";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg halloween-card">
                <div class="card-header bg-dark border-bottom border-secondary text-center py-4">
                    <div class="mb-3">
                        <i class="bi bi-person-circle display-1 text-orange"></i>
                    </div>
                    <h2 class="text-white">Здравей, @ViewBag.Username!</h2>
                    <span class="badge bg-secondary border border-light rounded-pill px-3 py-2 mt-2">
                        <i class="bi @roleIcon"></i> @string.Join(", ", roles)
                    </span>
                </div>

                <div class="card-body p-4">
                    <h5 class="text-orange border-bottom border-secondary pb-2 mb-3">
                        <i class="bi bi-info-circle"></i> Данни за акаунта
                    </h5>

                    <div class="row mb-4">
                        <div class="col-md-4 text-muted">Email:</div>
                        <div class="col-md-8 fw-bold text-white">@ViewBag.Email</div>
                    </div>
                    <div class="row mb-4">
                        <div class="col-md-4 text-muted">User ID:</div>
                        <div class="col-md-8 text-muted small">@ViewBag.Id</div>
                    </div>

                    @if (roles.Contains("Administrator"))
                    {
                        <div class="alert alert-dark border-danger mt-4">
                            <h5 class="text-danger"><i class="bi bi-gear-wide-connected"></i> Админ Панел</h5>
                            <p class="small text-muted">Вие имате силата да управлявате света на костюмите.</p>
                            <div class="d-grid gap-2 d-md-block">
                                <a asp-controller="Costumes" asp-action="Create" class="btn btn-spooky-orange btn-sm">
                                    <i class="bi bi-plus-circle"></i> Добави костюм
                                </a>
                                <a asp-controller="Costumes" asp-action="Index" class="btn btn-outline-light btn-sm">
                                    <i class="bi bi-list-ul"></i> Управление на костюми
                                </a>
                            </div>
                        </div>
                    }

                    <div class="mt-4">
                        <h5 class="text-purple border-bottom border-secondary pb-2 mb-3">
                            <i class="bi bi-basket"></i> Моите дейности
                        </h5>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="p-3 border border-secondary rounded bg-dark text-center">
                                    <h3 class="text-white">0</h3>
                                    <p class="text-muted small mb-0">Активни наеми</p>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="p-3 border border-secondary rounded bg-dark text-center">
                                    <h3 class="text-white">0 лв.</h3>
                                    <p class="text-muted small mb-0">Дължима сума</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card-footer bg-transparent border-top border-secondary text-center p-3">
                    <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                        <button type="submit" class="btn btn-outline-danger btn-sm px-4">
                            <i class="bi bi-box-arrow-right"></i> Изход
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>