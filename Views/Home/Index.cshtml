@model HomeViewModel
@{
    ViewData["Title"] = "Добре дошли";
}

<div class="hero-section rounded-4 p-5 mb-5 text-center text-lg-start position-relative overflow-hidden">
    <div class="row align-items-center position-relative z-2">
        <div class="col-lg-7 py-5">
            <h1 class="display-3 fw-bolder mb-3 text-white">
                Търсиш <span class="text-orange">костюм?</span><br />
                Не се плаши!
            </h1>
            <p class="lead mb-4 text-light opacity-75">
                Най-богатата колекция от страшни, забавни и уникални костюми за вашето парти.
                Резервирайте днес, преди призраците да са ги отмъкнали!
            </p>
            <div class="d-flex gap-3 justify-content-center justify-content-lg-start">
                <a asp-controller="Costumes" asp-action="Index" class="btn btn-halloween btn-lg px-5 rounded-pill">
                    <i class="bi bi-search me-2"></i>Разгледай
                </a>
                @if (!User.Identity.IsAuthenticated)
                {
                    <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-outline-halloween btn-lg px-4 rounded-pill">
                        Регистрация
                    </a>
                }
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-5 text-center">
    <div class="col-md-4">
        <div class="p-4 rounded-4 spooky-card">
            @* ИЗПОЛЗВАМЕ МОДЕЛА ВМЕСТО VIEWBAG *@
            <h2 class="display-4 fw-bold text-orange">@Model.TotalCostumes</h2>
            <p class="text-uppercase small letter-spacing-2 mb-0">Общо Костюма</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="p-4 rounded-4 spooky-card">
            @* ИЗПОЛЗВАМЕ МОДЕЛА ВМЕСТО VIEWBAG *@
            <h2 class="display-4 fw-bold text-success">@Model.AvailableCount</h2>
            <p class="text-uppercase small letter-spacing-2 mb-0">Свободни Сега</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="p-4 rounded-4 spooky-card">
            @* МОЖЕШ ДА ДОБАВИШ И КЛИЕНТИТЕ ТУК, АКО ЖЕЛАЕШ *@
            <h2 class="display-4 fw-bold text-purple">@Model.TotalClients</h2>
            <p class="text-uppercase small letter-spacing-2 mb-0">Наши Клиенти</p>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-end mb-4">
    <h2 class="fw-bold mb-0"><i class="bi bi-stars text-warning me-2"></i>Топ Предложения</h2>
    <a asp-controller="Costumes" asp-action="Index" class="text-decoration-none text-orange fw-bold">
        Виж всички <i class="bi bi-arrow-right"></i>
    </a>
</div>

<div class="row row-cols-1 row-cols-md-3 g-4 mb-5">
    @if (Model.FeaturedCostumes != null && Model.FeaturedCostumes.Any())
    {
        @foreach (var item in Model.FeaturedCostumes)
        {
            <div class="col">
                <div class="card h-100 spooky-card border-0 rounded-4 overflow-hidden">
                    <div class="ratio ratio-4x3 bg-dark">
                        @if (!string.IsNullOrEmpty(item.ImagePath))
                        {
                            <img src="@item.ImagePath" class="object-fit-cover w-100 h-100" alt="@item.Name" loading="lazy" />
                        }
                        else
                        {
                            <div class="d-flex align-items-center justify-content-center h-100 text-muted">
                                <i class="bi bi-image fs-1 opacity-25"></i>
                            </div>
                        }
                    </div>
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="badge bg-purple text-white">@item.Category?.Name</span>
                            <span class="fw-bold text-orange">@item.PricePerDay.ToString("F2") лв.</span>
                        </div>
                        <h5 class="card-title fw-bold">@item.Name</h5>
                        <p class="card-text small text-muted text-truncate-2">
                            @(string.IsNullOrEmpty(item.Notes) ? "Страхотен избор за вашето парти!" : item.Notes)
                        </p>
                    </div>
                    <div class="card-footer bg-transparent border-top-0 pb-3 pt-0">
                        <a asp-controller="Costumes" asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-light w-100 rounded-3">Детайли</a>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center py-5">
            <p class="text-muted">Все още няма добавени костюми в базата.</p>
        </div>
    }
</div>

@* СЕКЦИЯТА "КАК ДА НАЕМЕШ" И <STYLE> ОСТАВАТ СЪЩИТЕ *@

<div class="py-5 my-5 border-top border-white border-opacity-5">
    <div class="text-center mb-5">
        <h2 class="display-5 fw-bold text-white">Как да наемеш?</h2>
    </div>
    <div class="row g-4 text-center">
        <div class="col-md-4">
            <div class="step-blob mb-4 mx-auto"><i class="bi bi-search fs-2"></i></div>
            <h5 class="fw-bold">Избери костюм</h5>
            <p class="text-muted small px-lg-5">Разгледай каталога и избери перфектната визия за твоето събитие.</p>
        </div>
        <div class="col-md-4">
            <div class="step-blob mb-4 mx-auto"><i class="bi bi-calendar-event fs-2"></i></div>
            <h5 class="fw-bold">Резервирай</h5>
            <p class="text-muted small px-lg-5">Избери дати и попълни данните си. Ние ще подготвим всичко за теб.</p>
        </div>
        <div class="col-md-4">
            <div class="step-blob mb-4 mx-auto"><i class="bi bi-mask fs-2"></i></div>
            <h5 class="fw-bold">Парти време!</h5>
            <p class="text-muted small px-lg-5">Вземи костюма от магазина и бъди звездата на вечерта.</p>
        </div>
    </div>
</div>

<style>
    .bg-purple {
        background-color: var(--witch-purple) !important;
    }

    .text-truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    :root {
        --theme-orange: #ff851b;
        --witch-purple: #6f42c1;
    }

    /* Анимация за героя */
    .bi-emoji-grimace {
        animation: float 6s ease-in-out infinite;
    }

    @@keyframes float {
        0%, 100%

    {
        transform: translateY(0) rotate(0);
    }

    50% {
        transform: translateY(-20px) rotate(8deg);
    }

    }

    /* Блобове за стъпките */
    .step-blob {
        width: 80px;
        height: 80px;
        background: rgba(255, 133, 27, 0.1);
        color: var(--theme-orange);
        border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.5s ease;
    }

    /* Социални линкове */
    .social-link {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255, 255, 255, 0.05);
        color: white;
        border-radius: 50%;
        text-decoration: none;
        transition: all 0.3s;
    }

        .social-link:hover {
            background: var(--theme-orange);
            color: black;
            transform: translateY(-3px);
        }

    /* Ховър ефект за картите с костюми */
    .spooky-card {
        transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.4s;
    }

        .spooky-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 35px rgba(255, 133, 27, 0.15) !important;
        }

    .testimonial-card {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.05);
        transition: all 0.3s ease;
    }

        .testimonial-card:hover {
            background: rgba(111, 66, 193, 0.05); /* Леко лилаво */
            border-color: var(--witch-purple);
        }

    /* Стил за акордеона */
    .accordion-button:not(.collapsed) {
        background-color: transparent;
        color: var(--theme-orange);
        box-shadow: none;
    }

    .accordion-button::after {
        filter: invert(1); /* Прави стрелката на акордеона бяла */
    }

    .italic {
        font-style: italic;
    }
</style>
