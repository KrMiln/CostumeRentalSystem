@model HomeViewModel
@{
    ViewData["Title"] = "Добре дошли";
}

<div class="hero-section rounded-4 p-5 mb-5 text-center text-lg-start position-relative overflow-hidden">
    <div class="row align-items-center position-relative z-2">
        <div class="col-lg-7 py-5">
            <h1 class="display-3 fw-bolder mb-3 text-white">
                Търсиш <span class="text-orange">костюм?</span><br />
                Не се плаши!
            </h1>
            <p class="lead mb-4 text-light opacity-75">
                Най-богатата колекция от страшни, забавни и уникални костюми за вашето парти.
                Резервирайте днес, преди призраците да са ги отмъкнали!
            </p>
            <div class="d-flex gap-3 justify-content-center justify-content-lg-start">
                <a asp-controller="Costumes" asp-action="Index" class="btn btn-halloween btn-lg px-5 rounded-pill">
                    <i class="bi bi-search me-2"></i>Разгледай
                </a>
                @if (!User.Identity.IsAuthenticated)
                {
                    <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-outline-halloween btn-lg px-4 rounded-pill">
                        Регистрация
                    </a>
                }
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-5 text-center">
    <div class="col-md-4">
        <div class="p-4 rounded-4 spooky-card">
            <h2 class="display-4 fw-bold text-orange">@Model.TotalCostumes</h2>
            <p class="text-uppercase small letter-spacing-2 mb-0">Общо Костюма</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="p-4 rounded-4 spooky-card">
            <h2 class="display-4 fw-bold text-success">@Model.AvailableCount</h2>
            <p class="text-uppercase small letter-spacing-2 mb-0">Свободни Сега</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="p-4 rounded-4 spooky-card">
            <h2 class="display-4 fw-bold text-purple">@Model.TotalClients</h2>
            <p class="text-uppercase small letter-spacing-2 mb-0">Наши Клиенти</p>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-end mb-4">
    <h2 class="fw-bold mb-0"><i class="bi bi-stars text-warning me-2"></i>Топ Предложения</h2>
    <a asp-controller="Costumes" asp-action="Index" class="text-decoration-none text-orange fw-bold">
        Виж всички <i class="bi bi-arrow-right"></i>
    </a>
</div>

<div class="row row-cols-1 row-cols-md-3 g-4 mb-5">
    @if (Model.FeaturedCostumes != null && Model.FeaturedCostumes.Any())
    {
        @foreach (var item in Model.FeaturedCostumes)
        {
            <div class="col">
                <div class="card h-100 spooky-card border-0 rounded-4 overflow-hidden">
                    <div class="ratio ratio-4x3 bg-dark">
                        @if (!string.IsNullOrEmpty(item.ImagePath))
                        {
                            <img src="@item.ImagePath" class="object-fit-cover w-100 h-100" alt="@item.Name" loading="lazy" />
                        }
                        else
                        {
                            <div class="d-flex align-items-center justify-content-center h-100 text-muted">
                                <i class="bi bi-image fs-1 opacity-25"></i>
                            </div>
                        }
                    </div>
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="badge bg-purple text-white">@item.Category?.Name</span>
                            <span class="fw-bold text-orange">@item.PricePerDay.ToString("F2") лв.</span>
                        </div>
                        <h5 class="card-title fw-bold">@item.Name</h5>
                        <p class="card-text small text-muted text-truncate-2">
                            @(string.IsNullOrEmpty(item.Notes) ? "Страхотен избор за вашето парти!" : item.Notes)
                        </p>
                    </div>
                    <div class="card-footer bg-transparent border-top-0 pb-3 pt-0">
                        <a asp-controller="Costumes" asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-light w-100 rounded-3">Детайли</a>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center py-5">
            <p class="text-muted">Все още няма добавени костюми в базата.</p>
        </div>
    }
</div>
<div class="py-5 my-5 border-top border-white border-opacity-5">
    <div class="text-center mb-5">
        <h2 class="display-5 fw-bold text-white mb-3">Как да наемеш?</h2>
        <p class="text-muted mx-auto" style="max-width: 600px;">Целият процес отнема само няколко минути. Следвай стъпките и се приготви за купона!</p>
    </div>
    <div class="row g-4 text-center">
        <div class="col-md-4">
            <div class="mb-4 mx-auto d-flex align-items-center justify-content-center rounded-circle shadow-lg"
                 style="width: 100px; height: 100px; background: rgba(253, 126, 20, 0.1); border: 2px dashed #fd7e14;">
                <i class="bi bi-search fs-1 text-orange"></i>
            </div>
            <h4 class="fw-bold text-white">1. Избери модел</h4>
            <p class="text-muted small px-lg-5">Разгледай богатия ни каталог и намери костюма, който най-добре пасва на твоя характер.</p>
        </div>

        <div class="col-md-4">
            <div class="mb-4 mx-auto d-flex align-items-center justify-content-center rounded-circle shadow-lg"
                 style="width: 100px; height: 100px; background: rgba(111, 66, 193, 0.1); border: 2px dashed #6f42c1;">
                <i class="bi bi-calendar-check fs-1 text-purple"></i>
            </div>
            <h4 class="fw-bold text-white">2. Резервирай</h4>
            <p class="text-muted small px-lg-5">Избери дати през календара и попълни данните си. Ние ще потвърдим наличността веднага.</p>
        </div>

        <div class="col-md-4">
            <div class="mb-4 mx-auto d-flex align-items-center justify-content-center rounded-circle shadow-lg"
                 style="width: 100px; height: 100px; background: rgba(25, 135, 84, 0.1); border: 2px dashed #198754;">
                <i class="bi bi-mask fs-1 text-success"></i>
            </div>
            <h4 class="fw-bold text-white">3. Парти време!</h4>
            <p class="text-muted small px-lg-5">Вземи готовия костюм от нашия магазин и се превърни в звездата на вечерта.</p>
        </div>
    </div>
</div>

<div class="row g-4 mb-5 pt-5 border-top border-white border-opacity-5">
    <div class="col-12 text-center mb-4">
        <h2 class="fw-bold text-white">Къде да ни намериш?</h2>
        <p class="text-muted small">Лесен достъп в центъра на града и удобен паркинг за клиенти.</p>
    </div>

    <div class="col-lg-4">
        <div class="p-4 rounded-4 spooky-card h-100 bg-dark border border-secondary border-opacity-25 shadow-lg d-flex flex-column">
            <div class="mb-4">
                <h5 class="text-orange fw-bold mb-2"><i class="bi bi-geo-alt-fill text-orange me-2"></i>Нашият адрес</h5>
                <p class="text-white opacity-75 mb-0">
                    бул. "Княз Александър Дондуков" №13,<br />
                    <span>1000 София, България</span>
                </p>
            </div>

            <div class="mb-4">
                <h5 class="text-purple fw-bold mb-3"><i class="bi bi-clock-history me-2"></i>Работно време</h5>
                <div class="small">
                    <div class="d-flex justify-content-between border-bottom border-secondary border-opacity-10 py-2">
                        <span class="text-white-50">Пон - Пет</span>
                        <span class="text-white">08:00 - 17:00</span>
                    </div>
                    <div class="d-flex justify-content-between border-bottom border-secondary border-opacity-10 py-2">
                        <span class="text-white-50">Събота</span>
                        <span class="text-white">09:00 - 15:00</span>
                    </div>
                    <div class="d-flex justify-content-between py-2">
                        <span class="text-white-50">Неделя</span>
                        <span class="text-white">Почивен ден</span>
                    </div>
                </div>
            </div>

            <div class="mt-auto">
                <a href="https://maps.google.com" target="_blank" class="btn btn-outline-orange w-100 rounded-pill btn-sm py-2">
                    <i class="bi bi-arrow-up-right-circle me-2"></i>Навигация до нас
                </a>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="rounded-4 overflow-hidden border border-secondary border-opacity-25 shadow-lg h-100" style="min-height: 400px;">
            <iframe width="100%"
                    height="100%"
                    frameborder="0"
                    scrolling="no"
                    marginheight="0"
                    marginwidth="0"
                    src="https://maps.google.com/maps?q=Sofia,Dondukov%2013&t=&z=15&ie=UTF8&iwloc=&output=embed"
                    style="filter: grayscale(1) invert(92%) contrast(1.1) brightness(0.9); border:0; min-height: 400px;"
                    allowfullscreen=""
                    loading="lazy">
            </iframe>
        </div>
    </div>
</div>