@model IEnumerable<CostumeRentalSystem.Models.Costume>
@{
    ViewData["Title"] = "Добре дошли в Ада";
}

<div class="hero-section rounded-4 p-5 mb-5 text-center text-lg-start position-relative overflow-hidden">
    <div class="row align-items-center position-relative z-2">
        <div class="col-lg-7 py-5">
            <h1 class="display-3 fw-bolder mb-3 text-white">
                Търсиш <span class="text-orange">костюм?</span><br />
                Не се плаши!
            </h1>
            <p class="lead mb-4 text-light opacity-75">
                Най-богатата колекция от страшни, забавни и уникални костюми за вашето парти.
                Резервирайте днес, преди призраците да са ги отмъкнали!
            </p>
            <div class="d-flex gap-3 justify-content-center justify-content-lg-start">
                <a asp-controller="Costumes" asp-action="Index" class="btn btn-halloween btn-lg px-5 rounded-pill">
                    <i class="bi bi-search me-2"></i>Разгледай
                </a>
                @if (!User.Identity.IsAuthenticated)
                {
                    <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-outline-halloween btn-lg px-4 rounded-pill">
                        Регистрация
                    </a>
                }
            </div>
        </div>
    </div>
    <div class="position-absolute bottom-0 end-0 p-5 opacity-25 d-none d-lg-block">
        <i class="bi bi-emoji-grimace display-1 text-white"></i>
    </div>
</div>

<div class="row g-4 mb-5 text-center">
    <div class="col-md-4">
        <div class="p-4 rounded-4 spooky-card">
            <h2 class="display-4 fw-bold text-orange">@ViewBag.TotalCostumes</h2>
            <p class="text-uppercase small letter-spacing-2 mb-0">Общо Костюма</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="p-4 rounded-4 spooky-card">
            <h2 class="display-4 fw-bold text-success">@ViewBag.AvailableCount</h2>
            <p class="text-uppercase small letter-spacing-2 mb-0">Свободни Сега</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="p-4 rounded-4 spooky-card">
            <h2 class="display-4 fw-bold text-purple">24/7</h2>
            <p class="text-uppercase small letter-spacing-2 mb-0">Онлайн Резервации</p>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-end mb-4">
    <h2 class="fw-bold mb-0"><i class="bi bi-stars text-warning me-2"></i>Топ Предложения</h2>
    <a asp-controller="Costumes" asp-action="Index" class="text-decoration-none text-orange fw-bold">
        Виж всички <i class="bi bi-arrow-right"></i>
    </a>
</div>

<div class="row row-cols-1 row-cols-md-3 g-4 mb-5">
    @if (Model != null && Model.Any())
    {
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 spooky-card border-0 rounded-4 overflow-hidden">
                    <div class="ratio ratio-4x3 bg-dark">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" class="object-fit-cover w-100 h-100" alt="@item.Name" loading="lazy" />
                        }
                        else
                        {
                            <div class="d-flex align-items-center justify-content-center h-100 text-muted">
                                <i class="bi bi-image fs-1 opacity-25"></i>
                            </div>
                        }
                    </div>
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="badge bg-purple text-white">@item.Category?.Name</span>
                            <span class="fw-bold text-orange">@item.PricePerDay.ToString("F0") лв.</span>
                        </div>
                        <h5 class="card-title fw-bold">@item.Name</h5>
                        <p class="card-text small text-muted text-truncate-2">
                            @(string.IsNullOrEmpty(item.Notes) ? "Страхотен избор за вашето парти!" : item.Notes)
                        </p>
                    </div>
                    <div class="card-footer bg-transparent border-top-0 pb-3 pt-0">
                        <a asp-controller="Costumes" asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-light w-100 rounded-3">Детайли</a>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center py-5">
            <p class="text-muted">Все още няма добавени костюми в базата.</p>
        </div>
    }
</div>

<div class="row g-4 mb-5">
    <div class="col-md-6">
        <div class="h-100 p-5 rounded-4 bg-dark border border-secondary border-opacity-25">
            <h3><i class="bi bi-geo-alt-fill text-danger me-2"></i>Къде сме?</h3>
            <p class="text-muted mt-3">
                Нашият магазин се намира в центъра на града, точно до старото гробище... шегуваме се!
                Намираме се на удобно място с паркинг.
            </p>
            <ul class="list-unstyled mt-4 text-muted">
                <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i>Проба на място</li>
                <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i>Професионално почистване</li>
                <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i>Гъвкави условия</li>
            </ul>
        </div>
    </div>
    <div class="col-md-6">
        <div class="h-100 rounded-4 overflow-hidden shadow-lg" style="min-height: 300px; background-image: url('https://images.unsplash.com/photo-1545622081-3091bd670c53?q=80&w=1000&auto=format&fit=crop'); background-size: cover;">
            <div class="h-100 w-100 d-flex align-items-center justify-content-center bg-black bg-opacity-50">
                <span class="text-white fw-bold fs-4 border border-light px-4 py-2">ЗАПОВЯДАЙТЕ</span>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-purple {
        background-color: var(--witch-purple) !important;
    }

    .text-truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>