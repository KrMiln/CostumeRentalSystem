@model CostumeRentalSystem.Models.Rental
@{
    ViewData["Title"] = "Детайли за наем";
}

<h1>Детайли за наем</h1>

<div class="mt-3">
    <dl class="row">
        <dt class="col-sm-2">Клиент</dt>
        <dd class="col-sm-10">@Model.Client?.Name</dd>
        <dt class="col-sm-2">Костюм</dt>
        <dd class="col-sm-10">@Model.Costume?.Name (@Model.Costume?.Category?.Name)</dd>
        <dt class="col-sm-2">Дата на наемане</dt>
        <dd class="col-sm-10">@Model.RentDate.ToShortDateString()</dd>
        <dt class="col-sm-2">Дата на връщане</dt>
        <dd class="col-sm-10">@Model.ReturnDate.ToShortDateString()</dd>
        <dt class="col-sm-2">Статус</dt>
        <dd class="col-sm-10">@Model.Status</dd>
    </dl>
</div>

<a asp-action="Index" class="btn btn-secondary">Назад към списъка</a>
@if (Model.Status == CostumeRentalSystem.Models.RentalStatus.Активен && (User.IsInRole("Administrator") || User.IsInRole("Employee")))
{
    <a asp-action="Return" asp-route-id="@Model.Id" class="btn btn-success">Отбележи като върнат</a>
}

