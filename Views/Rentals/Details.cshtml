@model Rental
@{
    ViewData["Title"] = "Детайли за наем";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-xl-10">

            <div class="glass-panel overflow-hidden">

                <div class="glass-header p-4 d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-orange text-uppercase tracking-widest fw-bold mb-1" style="font-size: 1rem; opacity: 0.8;">Преглед на запис</h6>
                        <h2 class="text-white fw-light mb-0">Наем <span class="fw-bold">#@Model.Id</span></h2>
                    </div>
                    <div class="status-pill-internal @Model.Status.ToString().ToLower()">
                        @switch (Model.Status)
                        {
                            case RentalStatus.Active:
                                @:<i class="bi bi-clock-history me-2"></i> Нает
                                break;
                            case RentalStatus.Returned:
                                @:<i class="bi bi-check2-all me-2"></i> Върнат
                                break;
                            case RentalStatus.Lost:
                                @:<i class="bi bi-patch-exclamation me-2"></i> Изгубен
                                break;
                            case RentalStatus.Damaged:
                                @:<i class="bi bi-patch-exclamation me-2"></i> Повреден
                                break;
                            default:
                                @:<i class="bi bi-info-circle me-2"></i> @Model.Status
                                break;
                        }
                    </div>
                </div>

                <div class="p-4 p-md-5">
                    <div class="row g-5">
                        <div class="col-lg-6">
                            <h2 class="section-title mb-4">Информация за наемателя</h2>
                            <div class="mb-4">
                                <label class="custom-label">Клиент</label>
                                <div class="text-white fs-5">@Model.Client?.Name</div>
                            </div>
                            <div class="mb-0">
                                <label class="custom-label">Избран костюм</label>
                                <div class="text-white fs-5">@Model.Costume?.Name</div>
                            </div>
                        </div>

                        <div class="col-lg-6 border-start border-white border-opacity-10">
                            <div class="ps-lg-4">
                                <h5 class="section-title mb-4">Период на ползване</h5>
                                <div class="row">
                                    <div class="col-6">
                                        <label class="custom-label">Дата на наемане</label>
                                        <div class="text-white h5 fw-light">@Model.RentDate.ToString("dd.MM.yyyy")</div>
                                    </div>
                                    <div class="col-6 text-end text-lg-start">
                                        <label class="custom-label text-orange">Дата на връщане</label>
                                        <div class="text-white h5">@Model.ReturnDate.ToString("dd.MM.yyyy")</div>
                                    </div>
                                </div>
                                <div class="mt-4 p-3 rounded-3 bg-black bg-opacity-20 border border-white border-opacity-5">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span class="small text-muted fw-bold">Срок:</span>
                                        <span class="text-white">@((Model.ReturnDate - Model.RentDate).Days) дни</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-5 pt-5 border-top border-white border-opacity-5 d-flex justify-content-between">
                        <a asp-action="Index" class="btn-action-outline-large">
                            <i class="bi bi-arrow-left me-2"></i> Назад
                        </a>

                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-action-primary-large">
                            Редактирай наема <i class="bi bi-pencil-square ms-2"></i>
                        </a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<style>
    :root {
        --theme-orange: #ff851b;
        --glass-bg: rgba(255, 255, 255, 0.02);
        --glass-border: rgba(255, 255, 255, 0.1);
    }

    body {
        background-color: #0d0d0d;
        color: #eee;
    }

    .glass-panel {
        background: var(--glass-bg);
        backdrop-filter: blur(15px);
        border: 1px solid var(--glass-border);
        border-radius: 24px;
    }

    .glass-header {
        background: rgba(255, 255, 255, 0.03);
        border-bottom: 1px solid var(--glass-border);
    }

    /* Вътрешен статус индикатор */
    .status-pill-internal {
        padding: 8px 16px;
        border-radius: 12px;
        font-size: 0.75rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 1px;
        background: rgba(0,0,0,0.3);
    }

        .status-pill-internal.active {
            color: #007bff;
            border: 1px solid rgba(0,123,255,0.3);
        }

        .status-pill-internal.returned {
            color: #28a745;
            border: 1px solid rgba(40,167,69,0.3);
        }

        .status-pill-internal.lost {
            background: rgba(220, 53, 69, 0.1);
            color: #dc3545;
        }

        .status-pill-internal.damaged {
            background: rgba(142, 68, 173, 0.15); 
            color: #a34dff;
            border: 1px solid rgba(163, 77, 255, 0.3);
        }

    /* Големи и модерни бутони */
    .btn-action-outline-large {
        padding: 12px 30px;
        border: 1px solid var(--glass-border);
        background: transparent;
        color: #888;
        text-decoration: none;
        border-radius: 14px;
        font-size: 0.9rem;
        font-weight: 700;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
    }

        .btn-action-outline-large:hover {
            background: rgba(255,255,255,0.05);
            color: #fff;
            border-color: #fff;
        }

    .btn-action-primary-large {
        padding: 12px 35px;
        background: var(--theme-orange);
        color: #000;
        border: none;
        text-decoration: none;
        border-radius: 14px;
        font-size: 0.9rem;
        font-weight: 800;
        text-transform: uppercase;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        box-shadow: 0 4px 15px rgba(255, 133, 27, 0.2);
    }

        .btn-action-primary-large:hover {
            background: #fff;
            color: #000;
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(255, 133, 27, 0.3);
        }

    .section-title {
        color: white;
        font-size: 1.1rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1.2px;
    }

    .custom-label {
        font-size: 1rem;
        color: #555;
        text-transform: uppercase;
        font-weight: 800;
        margin-bottom: 5px;
        display: block;
    }

    .text-orange {
        color: var(--theme-orange);
    }

    .tracking-widest {
        letter-spacing: 2px;
    }
</style>