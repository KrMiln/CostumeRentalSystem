@model RentalIndexViewModel

@{
    ViewData["Title"] = "Управление на наеми";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom border-secondary">
        <div>
            <h1 class="text-white fw-bold mb-0">
                <i class="bi bi-calendar2-week me-2 text-orange"></i>Наеми
            </h1>
            <p class="text-muted mb-0">Пълен списък на активни и приключени наеми</p>
        </div>

        <a asp-action="Create" class="btn btn-ghost-orange fw-bold px-4">
            <i class="bi bi-plus-circle-fill me-2"></i>НОВ НАЕМ
        </a>
    </div>

    <div class="card mb-4 border-0 spooky-card shadow">
        <div class="card-header border-bottom border-secondary border-opacity-25 bg-transparent py-3">
            <h6 class="m-0 fw-bold text-orange"><i class="bi bi-filter"></i> Филтриране</h6>
        </div>
        <div class="card-body py-3">
            <form asp-action="Index" method="get" class="d-flex flex-wrap align-items-end gap-3">

                <div style="flex: 2; min-width: 200px;">
                    <label class="form-label text-muted small fw-bold text-uppercase">Клиент или Костюм</label>
                    <input type="text" name="searchString" value="@Model.SearchString"
                           class="form-control bg-dark text-white border-secondary shadow-none" placeholder="Търсене..." />
                </div>

                <div style="flex: 1; min-width: 130px;">
                    <label class="form-label text-muted small fw-bold text-uppercase">От дата</label>
                    <input type="date" name="startDate" value="@(Model.StartDate?.ToString("yyyy-MM-dd"))"
                           class="form-control bg-dark text-white border-secondary shadow-none" />
                </div>

                <div style="flex: 1; min-width: 130px;">
                    <label class="form-label text-muted small fw-bold text-uppercase">До дата</label>
                    <input type="date" name="endDate" value="@(Model.EndDate?.ToString("yyyy-MM-dd"))"
                           class="form-control bg-dark text-white border-secondary shadow-none" />
                </div>

                <div style="flex: 1.2; min-width: 150px;">
                    <label class="form-label text-muted small fw-bold text-uppercase">Статус</label>
                    <select asp-for="Status" class="form-select bg-dark text-white border-secondary shadow-none"
                            asp-items="Html.GetEnumSelectList<RentalStatus>()">
                        <option value="">-- Всички --</option>
                    </select>
                </div>

                <div class="d-flex gap-2 ms-auto">
                    <button type="submit" class="btn btn-ghost-white px-4 text-nowrap">
                        <i class="bi bi-search me-2"></i>Приложи
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary" title="Изчисти">
                        <i class="bi bi-arrow-clockwise"></i>
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 spooky-card shadow-lg overflow-hidden">
        <div class="table-responsive">
            <table class="table table-dark table-hover align-middle mb-0">
                <thead>
                    <tr class="text-uppercase small text-muted border-bottom border-secondary">
                        <th class="ps-4 py-3">Клиент</th>
                        <th class="py-3">Костюм</th>
                        <th class="py-3">Период</th>
                        <th class="py-3">Статус</th>
                        <th class="text-end pe-4 py-3">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Rentals.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted italic">
                                <i class="bi bi-exclamation-circle me-2"></i>Няма намерени наеми по тези критерии.
                            </td>
                        </tr>
                    }
                    @foreach (var item in Model.Rentals)
                    {
                        var isOverdue = item.Status == RentalStatus.Active && item.ReturnDate < DateTime.Today;

                        <tr class="border-bottom border-secondary-subtle @(isOverdue ? "overdue-row" : "")">
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <div class="avatar-circle me-3 @(isOverdue ? "border border-danger" : "")">
                                        @item.Client?.Name?.Substring(0, 1).ToUpper()
                                    </div>
                                    <div>
                                        <div class="fw-bold text-light">@item.Client?.Name</div>
                                        <div class="small text-muted" style="font-size: 0.7rem;">ID: #RE-@item.Id.ToString("D4")</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="text-orange fw-medium"><i class="bi bi-mask me-2"></i>@item.Costume?.Name</span>
                            </td>
                            <td>
                                <div class="small">
                                    <div class="text-muted">От: @item.RentDate.ToShortDateString()</div>
                                    <div class="@(isOverdue ? "text-danger fw-bold pulse" : "text-info")">
                                        До: @item.ReturnDate.ToShortDateString()
                                        @if (isOverdue)
                                        {
                                            <i class="bi bi-exclamation-triangle-fill ms-1"></i>
                                        }
                                    </div>
                                </div>
                            </td>
                            <td>
                                @{
                                    var badgeClass = item.Status switch
                                    {
                                        RentalStatus.Active => "badge-active",
                                        RentalStatus.Returned => "badge-returned",
                                        RentalStatus.Lost => "badge-lost",
                                        RentalStatus.Damaged => "badge-damaged",
                                        _ => "badge-other"
                                    };
                                }
                                <span class="custom-badge @badgeClass">
                                    <span class="dot"></span> @item.Status.GetDisplayName()
                                </span>
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group gap-1">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info"><i class="bi bi-pencil"></i></a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-light"><i class="bi bi-eye"></i></a>
                                    @if (User.IsInRole("Administrator"))
                                    {
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (Model.Pagination != null)
{
    <div class="mt-4">
        <partial name="_PaginationPartial" model="Model.Pagination" />
    </div>
}

