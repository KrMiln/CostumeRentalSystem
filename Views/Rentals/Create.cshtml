@model CostumeRentalSystem.Models.Rental
@{
    ViewData["Title"] = "Нов наем";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-end mb-5">
        <div class="page-title-area">
            <h6 class="text-orange text-uppercase tracking-widest fw-bold mb-1" style="font-size: 0.7rem; opacity: 0.8;">Система за управление</h6>
            <h2 class="text-white fw-light mb-0">Регистрация на <span class="fw-bold">Договор</span></h2>
        </div>
        <a asp-action="Index" class="btn btn-link text-muted text-decoration-none small p-0 hover-white">
            <i class="bi bi-arrow-left me-1"></i> Обратно към списъка
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-xl-10">
            <form asp-action="Create" method="post" class="rental-form">
                <div class="glass-panel p-4 p-md-5">

                    <div class="row g-5">
                        <div class="col-lg-6">
                            <h5 class="section-title mb-4">Информация за наема</h5>

                            <div class="custom-input-group mb-4">
                                <label asp-for="ClientId" class="custom-label">Клиент</label>
                                <div class="input-wrapper">
                                    <select asp-for="ClientId" class="custom-control" asp-items="ViewBag.ClientId">
                                        <option value="" disabled selected>Изберете клиент...</option>
                                    </select>
                                    <i class="bi bi-person-check icon-indicator"></i>
                                </div>
                                <span asp-validation-for="ClientId" class="text-danger x-small"></span>
                            </div>

                            <div class="custom-input-group mb-0">
                                <label asp-for="CostumeId" class="custom-label">Костюм</label>
                                <div class="input-wrapper">
                                    <select asp-for="CostumeId" class="custom-control" asp-items="ViewBag.CostumeId">
                                        <option value="" disabled selected>Изберете артикул...</option>
                                    </select>
                                    <i class="bi bi-mask icon-indicator"></i>
                                </div>
                                <span asp-validation-for="CostumeId" class="text-danger x-small"></span>
                            </div>
                        </div>

                        <div class="col-lg-6">
                            <h5 class="section-title mb-4">Период и Статус</h5>

                            <div class="row g-3">
                                <div class="col-sm-6">
                                    <div class="custom-input-group mb-4">
                                        <label asp-for="RentDate" class="custom-label">От дата</label>
                                        <input asp-for="RentDate" class="custom-control date-input" type="date" />
                                        <span asp-validation-for="RentDate" class="text-danger x-small"></span>
                                    </div>
                                </div>
                                <div class="col-sm-6">
                                    <div class="custom-input-group mb-4">
                                        <label asp-for="ReturnDate" class="custom-label">До дата</label>
                                        <input asp-for="ReturnDate" class="custom-control date-input highlight" type="date" />
                                        <span asp-validation-for="ReturnDate" class="text-danger x-small"></span>
                                    </div>
                                </div>
                            </div>

                            <div class="custom-input-group mb-0">
                                <label asp-for="Status" class="custom-label">Статус на наема</label>
                                <div class="input-wrapper">
                                    <select asp-for="Status" class="custom-control"
                                            asp-items="Html.GetEnumSelectList<CostumeRentalSystem.Models.RentalStatus>()"></select>
                                    <i class="bi bi-activity icon-indicator"></i>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="form-actions mt-5 pt-4 border-top border-white border-opacity-10 text-end">
                        <button type="submit" class="btn-submit-main">
                            СЪЗДАЙ ДОГОВОР <i class="bi bi-plus-lg ms-2"></i>
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    /* Базови цветове за синхрон с темата */
    :root {
        --theme-orange: #ff851b;
        --theme-glass: rgba(255, 255, 255, 0.02);
        --theme-border: rgba(255, 255, 255, 0.08);
        --theme-input-bg: rgba(0, 0, 0, 0.2);
    }

    /* Glass Panel: Същият като в Index страницата */
    .glass-panel {
        background: var(--theme-glass);
        backdrop-filter: blur(12px);
        border: 1px solid var(--theme-border);
        border-radius: 20px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.4);
    }

    .section-title {
        color: white;
        font-size: 0.9rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        opacity: 0.9;
        display: flex;
        align-items: center;
    }

        .section-title::before {
            content: "";
            width: 15px;
            height: 2px;
            background: var(--theme-orange);
            margin-right: 10px;
        }

    /* Inputs: Рафинирани за тъмна тема */
    .custom-label {
        font-size: 0.7rem;
        color: #777;
        font-weight: 800;
        text-transform: uppercase;
        margin-bottom: 8px;
        display: block;
    }

    .input-wrapper {
        position: relative;
        display: flex;
        align-items: center;
    }

    .custom-control {
        width: 100%;
        background: var(--theme-input-bg);
        border: 1px solid var(--theme-border);
        color: #ddd;
        padding: 12px 15px;
        border-radius: 10px;
        font-size: 0.95rem;
        transition: all 0.3s ease;
        outline: none;
    }

        .custom-control:focus {
            border-color: var(--theme-orange);
            background: rgba(0,0,0,0.4);
            color: white;
        }

    .icon-indicator {
        position: absolute;
        right: 15px;
        color: #444;
        pointer-events: none;
    }

    .date-input.highlight {
        border-color: rgba(255, 133, 27, 0.3);
    }

    /* Button: Акцент без да доминира */
    .btn-submit-main {
        background: var(--theme-orange);
        border: none;
        color: black;
        padding: 12px 40px;
        border-radius: 10px;
        font-weight: 900;
        font-size: 0.85rem;
        letter-spacing: 1px;
        transition: all 0.3s;
    }

        .btn-submit-main:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(255, 133, 27, 0.2);
            background: #ffa04d;
        }

    /* Utility */
    .tracking-widest {
        letter-spacing: 3px;
    }

    .x-small {
        font-size: 0.7rem;
        margin-top: 5px;
        display: block;
    }

    .hover-white:hover {
        color: white !important;
    }

    ::-webkit-calendar-picker-indicator {
        filter: invert(0.8);
        cursor: pointer;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}