@model CostumeRentalSystem.Models.Rental
@{
    ViewData["Title"] = "Нов наем";
}

<h1>Нов наем</h1>

<form asp-action="Create" method="post" class="mt-3">
    <div class="mb-3">
        <label asp-for="ClientId" class="form-label"></label>
        <select asp-for="ClientId" class="form-select" asp-items="ViewBag.ClientId">
            <option value="">-- избор на клиент --</option>
        </select>
        <span asp-validation-for="ClientId" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="CostumeId" class="form-label"></label>
        <select asp-for="CostumeId" class="form-select" asp-items="ViewBag.CostumeId">
            <option value="">-- избор на костюм --</option>
        </select>
        <span asp-validation-for="CostumeId" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="RentDate" class="form-label"></label>
        <input asp-for="RentDate" class="form-control" />
        <span asp-validation-for="RentDate" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="ReturnDate" class="form-label"></label>
        <input asp-for="ReturnDate" class="form-control" />
        <span asp-validation-for="ReturnDate" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Status" class="form-label"></label>
        <select asp-for="Status" class="form-select" asp-items="Html.GetEnumSelectList<CostumeRentalSystem.Models.RentalStatus>()"></select>
        <span asp-validation-for="Status" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Запази</button>
    <a asp-action="Index" class="btn btn-secondary">Назад към списъка</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

