@model CostumeRentalSystem.Models.Rental

@{
    ViewData["Title"] = "Редакция на наем";
}

<div class="container mt-4">
    <div class="card shadow-lg border-0">
        <div class="card-header bg-warning text-dark">
            <h3 class="mb-0"><i class="bi bi-pencil-square me-2"></i>Редактиране на наем #@Model.Id</h3>
        </div>
        <div class="card-body bg-dark text-light">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="Id" />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="ClientId" class="form-label">Клиент</label>
                        <select asp-for="ClientId" class="form-select bg-secondary text-white border-0" asp-items="ViewBag.ClientId"></select>
                        <span asp-validation-for="ClientId" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="CostumeId" class="form-label">Костюм</label>
                        <select asp-for="CostumeId" class="form-select bg-secondary text-white border-0" asp-items="ViewBag.CostumeId"></select>
                        <span asp-validation-for="CostumeId" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="RentDate" class="form-label">Дата на наемане</label>
                        <input asp-for="RentDate" type="date" class="form-control bg-secondary text-white border-0" />
                        <span asp-validation-for="RentDate" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="ReturnDate" class="form-label">Дата на връщане</label>
                        <input asp-for="ReturnDate" type="date" class="form-control bg-secondary text-white border-0" />
                        <span asp-validation-for="ReturnDate" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label asp-for="Status" class="form-label">Статус на наема</label>
                        <select asp-for="Status" class="form-select bg-secondary text-white border-0"
                                asp-items="Html.GetEnumSelectList<CostumeRentalSystem.Models.RentalStatus>()">
                        </select>
                        <span asp-validation-for="Status" class="text-danger"></span>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-warning px-4 fw-bold">
                        <i class="bi bi-save me-1"></i> Запази промените
                    </button>
                    <a asp-action="Index" class="btn btn-outline-light">
                        <i class="bi bi-arrow-left me-1"></i> Назад
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}