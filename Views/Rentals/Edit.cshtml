@model RentalFormViewModel

@{
    ViewData["Title"] = "Редактиране на наем";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-end mb-5">
        <div class="page-title-area">
            <h6 class="text-orange text-uppercase tracking-widest fw-bold mb-1" style="font-size: 0.7rem; opacity: 0.8;">Система за управление</h6>
            <h2 class="text-white fw-light mb-0">Редактиране на <span class="fw-bold">Наем #@Model.Id</span></h2>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-xl-10">
            <form asp-action="Edit" method="post" class="rental-form">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="ClientId" />
                <input type="hidden" asp-for="CostumeId" />
                <input type="hidden" asp-for="PricePerDay" />
                <input type="hidden" asp-for="ClientName" />
                <input type="hidden" asp-for="CostumeName" />

                <div class="glass-panel p-4 p-md-5">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-4 x-small"></div>

                    <div class="row g-5">
                        <div class="col-lg-6">
                            <h5 class="section-title mb-4">Детайли на записа</h5>

                            <div class="custom-input-group mb-4">
                                <label class="custom-label">Клиент</label>
                                <div class="input-wrapper">
                                    <input type="text" class="custom-control" value="@Model.ClientName" readonly style="opacity: 0.7; cursor: not-allowed; padding-right: 40px;" />
                                    <i class="bi bi-lock-fill icon-indicator"></i>
                                </div>
                                <div class="validation-placeholder"></div>
                            </div>

                            <div class="custom-input-group mb-0">
                                <label class="custom-label">Костюм</label>
                                <div class="input-wrapper">
                                    <input type="text" class="custom-control" value="@Model.CostumeName" readonly style="opacity: 0.7; cursor: not-allowed; padding-right: 40px;" />
                                    <i class="bi bi-lock-fill icon-indicator"></i>
                                </div>
                                <div class="validation-placeholder"></div>
                            </div>
                        </div>

                        <div class="col-lg-6">
                            <h5 class="section-title mb-4">Период и Актуализация</h5>

                            <div class="row g-3">
                                <div class="col-sm-6">
                                    <div class="custom-input-group mb-0">
                                        <label asp-for="StartDate" class="custom-label">От дата</label>
                                        <input asp-for="StartDate" class="custom-control date-input" type="date" />
                                        <div class="validation-placeholder">
                                            <span asp-validation-for="StartDate" class="text-danger x-small"></span>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-sm-6">
                                    <div class="custom-input-group mb-0">
                                        <label asp-for="EndDate" class="custom-label">До дата</label>
                                        <input asp-for="EndDate" class="custom-control date-input highlight" type="date" />
                                        <div class="validation-placeholder">
                                            <span asp-validation-for="EndDate" class="text-danger x-small"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="custom-input-group mt-4 mb-0">
                                <label asp-for="Status" class="custom-label">Статус на наема</label>
                                <div class="input-wrapper">
                                    <select asp-for="Status" class="custom-control"
                                            asp-items="Html.GetEnumSelectList<RentalStatus>()"></select>
                                </div>
                                <div class="validation-placeholder">
                                    <span asp-validation-for="Status" class="text-danger x-small"></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="form-actions mt-5 pt-4 border-top border-white border-opacity-10 d-flex justify-content-between align-items-center">
                        <a asp-action="Index" class="btn btn-link text-muted text-decoration-none small hover-white fw-bold p-0">
                            <i class="bi bi-arrow-left me-1"></i> Назад
                        </a>

                        <button type="submit" class="btn-submit-main">
                            <i class="bi bi-save me-2"></i> ЗАПАЗИ ПРОМЕНИТЕ
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>



@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}