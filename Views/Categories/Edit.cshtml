@using CostumeRentalSystem.ViewModels.Categories
@model CategoryFormViewModel

@{
    ViewData["Title"] = "Редактиране на категория";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg halloween-card">
                <div class="card-header halloween-header-create text-white py-3">
                    <h4 class="mb-0"><i class="bi bi-pencil-square text-orange"></i> Редактиране на категория</h4>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="Id" />

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger bg-dark border-danger text-danger"></div>

                        <div class="mb-4">
                            <label asp-for="Name" class="form-label fw-bold text-orange">
                                <i class="bi bi-tag-fill me-1"></i> Име на категорията
                            </label>
                            <input asp-for="Name"
                                   class="form-control bg-dark text-white border-secondary focus-orange"
                                   placeholder="Променете името..." />
                            <span asp-validation-for="Name" class="text-danger small mt-2 d-block"></span>
                        </div>

                        <div class="mb-4 p-3 rounded bg-dark border border-dashed-orange">
                            <div class="d-flex align-items-center text-muted small">
                                <i class="bi bi-exclamation-octagon text-orange me-2 fs-5"></i>
                                <span>Внимание: Промяната ще се отрази на всички асоциирани костюми.</span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between pt-3 border-top border-secondary">
                            <a asp-action="Index" class="btn btn-outline-light px-4">
                                <i class="bi bi-arrow-left"></i> Назад
                            </a>
                            <button type="submit" class="btn btn-spooky-orange px-5 shadow">
                                <i class="bi bi-check-lg"></i> Запази промените
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
