@model CostumeRentalSystem.Models.Category

@{
    ViewData["Title"] = "Изтриване на категория";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg halloween-card border-danger">
                <div class="card-header bg-danger text-white py-3">
                    <h4 class="mb-0">
                        <i class="bi bi-exclamation-octagon-fill"></i> Внимание!
                    </h4>
                </div>

                <div class="card-body p-4 text-center">
                    <div class="mb-4">
                        <i class="bi bi-trash3 text-danger fs-1"></i>
                        <h3 class="text-white mt-3">Сигурни ли сте?</h3>
                        <p class="text-muted">На път сте да изтриете категорията завинаги.</p>
                    </div>

                    <div class="p-3 mb-4 rounded bg-dark border border-secondary text-start">
                        <div class="row align-items-center">
                            <div class="col-4 text-orange fw-bold">
                                <i class="bi bi-tag-fill me-1"></i> Име:
                            </div>
                            <div class="col-8 text-white fs-5">
                                @Model.Name
                            </div>
                        </div>
                    </div>

                    <div class="alert alert-dark border-danger text-danger small mb-4">
                        <i class="bi bi-skull-fill me-2"></i>
                        Ако има костюми, свързани с тази категория, изтриването може да бъде блокирано или да доведе до грешки.
                    </div>

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="Id" />

                        <div class="d-flex justify-content-between pt-3 border-top border-secondary">
                            <a asp-action="Index" class="btn btn-outline-light px-4">
                                <i class="bi bi-arrow-left"></i> Отказ
                            </a>
                            <button type="submit" class="btn btn-danger px-5 shadow-sm fw-bold">
                                <i class="bi bi-trash"></i> Потвърди изтриването
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>