@using CostumeRentalSystem.ViewModels.Categories
@model IEnumerable<CategoryIndexViewModel>
@{
    ViewData["Title"] = "Категории";
}

<div class="container py-5">
    <div class="row align-items-center mb-5">
        <div class="col">
            <h2 class="text-white fw-light mb-0">Категории <span class="fw-bold">костюми</span></h2>
        </div>

        @if (User.IsInRole("Administrator"))
        {
            <div class="col-auto">
                @if (Model.Count() < 10)
                {
                    <a asp-action="Create" class="btn-new-category">
                        <i class="bi bi-plus-circle-fill"></i>
                        <span>Нова Категория</span>
                    </a>
                }
                else
                {
                    <div class="d-flex align-items-center bg-dark border border-warning rounded-pill px-3 py-2">
                        <i class="bi bi-exclamation-triangle-fill text-warning me-2"></i>
                        <span class="text-white shadow-sm" style="font-size: 0.75rem; font-weight: 600;">Лимитът от 10 е достигнат</span>
                    </div>
                }
            </div>
        }
    </div>

    <div class="category-list">
        @if (!Model.Any())
        {
            <div class="text-center py-5" style="background: var(--row-bg); border-radius: 16px; border: 1px dashed rgba(255,255,255,0.1);">
                <i class="bi bi-folder2-open display-4 text-muted mb-3 d-block"></i>
                <p class="text-white-50">Все още няма добавени категории.</p>
            </div>
        }
        else
        {
            @foreach (var item in Model)
            {
                <div class="category-item-row">
                    <div class="row align-items-center w-100 g-0">
                        <div class="col-auto me-4">
                            <div class="mini-icon-box">
                                <i class="bi bi-bookmark-star"></i>
                            </div>
                        </div>

                        <div class="col">
                            <h5 class="item-title">@item.Name</h5>
                            <span class="item-subtitle">
                                <i class="bi bi-info-circle me-1"></i> Активна категория
                            </span>
                        </div>

                        @if (User.IsInRole("Administrator"))
                        {
                            <div class="col-auto">
                                <div class="button-group">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn-action edit" title="Редактирай">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn-action delete" title="Изтрий">
                                        <i class="bi bi-trash3"></i>
                                    </a>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        }
    </div>
</div>

<style>
    :root {
        --accent-orange: #ff851b;
        --row-bg: rgba(255, 255, 255, 0.04);
        --row-hover: rgba(255, 255, 255, 0.08);
    }

    .tracking-widest {
        letter-spacing: 3px;
    }

    /* New Category Button */
    .btn-new-category {
        background: transparent;
        color: var(--accent-orange);
        border: 2px solid var(--accent-orange);
        padding: 8px 24px;
        border-radius: 50px;
        text-decoration: none;
        font-weight: 700;
        font-size: 0.8rem;
        text-transform: uppercase;
        display: flex;
        align-items: center;
        gap: 10px;
        transition: all 0.3s ease;
    }

        .btn-new-category:hover {
            background: var(--accent-orange);
            color: #000;
            box-shadow: 0 0 20px rgba(255, 133, 27, 0.4);
        }

    /* List Container */
    .category-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    /* Row Styling */
    .category-item-row {
        background: var(--row-bg);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 16px;
        padding: 16px 24px;
        transition: all 0.2s ease-in-out;
        display: flex;
    }

        .category-item-row:hover {
            background: var(--row-hover);
            transform: scale(1.005);
            border-color: rgba(255, 133, 27, 0.3);
        }

    /* Icon Box */
    .mini-icon-box {
        width: 42px;
        height: 42px;
        background: rgba(255, 255, 255, 0.05);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--accent-orange);
        font-size: 1.2rem;
    }

    /* Text Content */
    .item-title {
        color: white;
        margin: 0;
        font-size: 1.1rem;
        font-weight: 600;
    }

    .item-subtitle {
        color: rgba(255, 255, 255, 0.4);
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    /* Action Buttons */
    .button-group {
        display: flex;
        gap: 8px;
    }

    .btn-action {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        transition: 0.2s;
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

        .btn-action.edit {
            color: #ffc107;
        }

            .btn-action.edit:hover {
                background: #ffc107;
                color: black;
                border-color: #ffc107;
            }

        .btn-action.delete {
            color: #ff4d4d;
        }

            .btn-action.delete:hover {
                background: #ff4d4d;
                color: white;
                border-color: #ff4d4d;
            }
</style>