@model IEnumerable<CostumeRentalSystem.Models.Category>
@{
    ViewData["Title"] = "Категории";
}

<h1 class="mb-3">Категории костюми</h1>

@if (User.IsInRole("Administrator") || User.IsInRole("Employee"))
{
    <p>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Нова категория
        </a>
    </p>
}

<table class="table table-striped table-hover shadow-sm rounded bg-white">
    <thead>
        <tr>
            <th>Име на категория</th>
            <th class="text-end">Действия</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
            <td>@item.Name</td>
            <td class="text-end">
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Детайли</a>
                @if (User.IsInRole("Administrator") || User.IsInRole("Employee"))
                {
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Редакция</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Изтриване</a>
                }
            </td>
        </tr>
}
    </tbody>
</table>

