@model IEnumerable<CostumeRentalSystem.Models.Category>
@{
    ViewData["Title"] = "Категории";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-end mb-5">
        <div>
            <h6 class="text-orange text-uppercase tracking-widest fw-bold mb-1" style="font-size: 0.7rem; opacity: 0.8;">Номенклатури</h6>
            <h2 class="text-white fw-light mb-0">Категории <span class="fw-bold">костюми</span></h2>
        </div>

        @if (User.IsInRole("Administrator"))
        {
            <a asp-action="Create" class="btn-add-category">
                <i class="bi bi-plus-lg"></i>
                <span>Добави</span>
            </a>
        }
    </div>

    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="glass-category-card">
                    <div class="card-content">
                        <div class="category-icon">
                            <i class="bi bi-tags-fill"></i>
                        </div>
                        <div class="category-info">
                            <h4 class="category-name">@item.Name</h4>
                            <p class="text-muted small mb-0">Каталожна категория</p>
                        </div>
                    </div>

                    @if (User.IsInRole("Administrator"))
                    {
                        <div class="card-actions">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="action-link edit" title="Редактирай">
                                <i class="bi bi-pencil-square"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="action-link delete" title="Изтрий">
                                <i class="bi bi-trash3"></i>
                            </a>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

<style>
    :root {
        --category-orange: #ff851b;
        --card-bg: rgba(255, 255, 255, 0.03);
        --card-border: rgba(255, 255, 255, 0.08);
    }

    .tracking-widest {
        letter-spacing: 3px;
    }

    /* Button Styling */
    .btn-add-category {
        background: var(--category-orange);
        color: black;
        text-decoration: none;
        padding: 10px 20px;
        border-radius: 12px;
        font-weight: 800;
        font-size: 0.85rem;
        text-transform: uppercase;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
    }

        .btn-add-category:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(255, 133, 27, 0.3);
            background: #ffa04d;
            color: black;
        }

    /* Category Card Styling */
    .glass-category-card {
        background: var(--card-bg);
        backdrop-filter: blur(10px);
        border: 1px solid var(--card-border);
        border-radius: 20px;
        padding: 25px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    }

        .glass-category-card:hover {
            background: rgba(255, 255, 255, 0.06);
            border-color: rgba(255, 133, 27, 0.4);
            transform: translateY(-5px);
        }

    .card-content {
        display: flex;
        align-items: center;
        gap: 20px;
    }

    .category-icon {
        width: 50px;
        height: 50px;
        background: rgba(255, 133, 27, 0.1);
        color: var(--category-orange);
        border-radius: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
    }

    .category-name {
        color: white;
        font-size: 1.15rem;
        font-weight: 700;
        margin: 0;
    }

    /* Actions Styling */
    .card-actions {
        display: flex;
        gap: 10px;
        opacity: 0.4;
        transition: opacity 0.3s ease;
    }

    .glass-category-card:hover .card-actions {
        opacity: 1;
    }

    .action-link {
        width: 35px;
        height: 35px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        transition: 0.2s;
        font-size: 1rem;
    }

        .action-link.edit {
            background: rgba(255, 193, 7, 0.1);
            color: #ffc107;
        }

            .action-link.edit:hover {
                background: #ffc107;
                color: black;
            }

        .action-link.delete {
            background: rgba(220, 53, 69, 0.1);
            color: #dc3545;
        }

            .action-link.delete:hover {
                background: #dc3545;
                color: white;
            }
</style>