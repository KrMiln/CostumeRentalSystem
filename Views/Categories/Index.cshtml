@using CostumeRentalSystem.ViewModels.Categories
@model IEnumerable<CategoryIndexViewModel>
@{
    ViewData["Title"] = "Категории";
}

<div class="container py-5">
    <div class="row align-items-center mb-5">
        <div class="col">
            <h2 class="text-white fw-light mb-0">Категории <span class="fw-bold">костюми</span></h2>
        </div>

        @if (User.IsInRole("Administrator"))
        {
            <div class="col-auto">
                @if (Model.Count() < 10)
                {
                    <a asp-action="Create" class="btn-new-category">
                        <i class="bi bi-plus-circle-fill"></i>
                        <span>Нова Категория</span>
                    </a>
                }
                else
                {
                    <div class="d-flex align-items-center bg-dark border border-warning rounded-pill px-3 py-2">
                        <i class="bi bi-exclamation-triangle-fill text-warning me-2"></i>
                        <span class="text-white shadow-sm" style="font-size: 0.75rem; font-weight: 600;">Лимитът от 10 е достигнат</span>
                    </div>
                }
            </div>
        }
    </div>

    <div class="category-list">
        @if (!Model.Any())
        {
            <div class="text-center py-5" style="background: var(--row-bg); border-radius: 16px; border: 1px dashed rgba(255,255,255,0.1);">
                <i class="bi bi-folder2-open display-4 text-muted mb-3 d-block"></i>
                <p class="text-white-50">Все още няма добавени категории.</p>
            </div>
        }
        else
        {
            @foreach (var item in Model)
            {
                <div class="category-item-row">
                    <div class="row align-items-center w-100 g-0">
                        <div class="col-auto me-4">
                            <div class="mini-icon-box">
                                <i class="bi bi-bookmark-star"></i>
                            </div>
                        </div>

                        <div class="col">
                            <h5 class="item-title">@item.Name</h5>
                            <span class="item-subtitle">
                                <i class="bi bi-info-circle me-1"></i> Активна категория
                            </span>
                        </div>

                        @if (User.IsInRole("Administrator"))
                        {
                            <div class="col-auto">
                                <div class="button-group">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn-action edit" title="Редактирай">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn-action delete" title="Изтрий">
                                        <i class="bi bi-trash3"></i>
                                    </a>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        }
    </div>
</div>

