@model CostumeRentalSystem.Models.Costume
@{
    ViewData["Title"] = "Детайли за костюм";
}

<h1 class="text-orange mb-4"><i class="bi bi-info-circle me-2"></i>Детайли за костюм</h1>

<div class="row">
    <div class="col-md-8">
        <div class="p-4 spooky-card rounded-4 border border-secondary border-opacity-25">
            <dl class="row mb-0">
                <dt class="col-sm-3 text-muted">Име</dt>
                <dd class="col-sm-9 fw-bold text-white fs-5">@Model.Name</dd>

                <dt class="col-sm-3 text-muted">Категория</dt>
                <dd class="col-sm-9 text-purple fw-bold">@Model.Category?.Name</dd>

                <dt class="col-sm-3 text-muted">Размер</dt>
                <dd class="col-sm-9 text-white">@Model.Size</dd>

                <dt class="col-sm-3 text-muted">Цена на ден</dt>
                <dd class="col-sm-9 text-orange fw-bold">@Model.PricePerDay.ToString("0.00") лв.</dd>

                <dt class="col-sm-3 text-muted">Наличност</dt>
                <dd class="col-sm-9">
                    @if (Model.IsAvailable)
                    {
                        <span class="badge bg-success">Наличен</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Зает</span>
                    }
                </dd>

                <dt class="col-sm-3 text-muted">Бележки</dt>
                <dd class="col-sm-9 text-white opacity-75">@(string.IsNullOrEmpty(Model.Notes) ? "-" : Model.Notes)</dd>
            </dl>
        </div>

        <div class="mt-4 d-flex gap-2">
            <a asp-action="Index" class="btn btn-outline-light px-4">Назад</a>
            @if (User.IsInRole("Administrator") || User.IsInRole("Employee"))
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Редакция</a>
            }
        </div>
    </div>

    <div class="col-md-4">
        @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
        {
            <div class="rounded-4 overflow-hidden border border-secondary shadow-lg">
                <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid w-100" style="object-fit:cover;" />
            </div>
        }
        else
        {
            <div class="rounded-4 bg-dark border border-secondary d-flex align-items-center justify-content-center text-muted" style="height: 300px;">
                Няма снимка
            </div>
        }
    </div>
</div>