@model Costume
@{
    ViewData["Title"] = "Детайли за " + Model.Name;
}

<div class="container py-4">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" class="text-orange text-decoration-none small text-uppercase fw-bold">Каталог</a></li>
            <li class="breadcrumb-item active text-white opacity-50 small text-uppercase" aria-current="page">@Model.Name</li>
        </ol>
    </nav>

    <div class="row g-5">
        <div class="col-lg-5">
            <div class="position-sticky" style="top: 20px;">
                @if (!string.IsNullOrWhiteSpace(Model.ImagePath))
                {
                    <div class="rounded-4 overflow-hidden border border-white border-opacity-10 shadow-2xl hover-zoom main-image-container position-relative">
                        <img src="@Model.ImagePath" alt="@Model.Name" class="img-fluid w-100" />

                        @if (!Model.IsAvailable)
                        {
                            <div class="status-overlay-spooky">
                                <i class="bi bi-exclamation-triangle-fill me-1"></i> ЗАЕТ
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="rounded-4 bg-dark border border-secondary d-flex flex-column align-items-center justify-content-center text-muted" style="height: 500px;">
                        <i class="bi bi-image fs-1 opacity-25 mb-2"></i>
                        <span class="small text-uppercase tracking-widest">Няма налична снимка</span>
                    </div>
                }

                <div class="row g-2 mt-3">
                    <div class="col-4">
                        <div class="feature-box">
                            <i class="bi bi-shield-check"></i>
                            <span>Дезинфекция</span>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="feature-box">
                            <i class="bi bi-magic"></i>
                            <span>Премиум</span>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="feature-box">
                            <i class="bi bi-truck"></i>
                            <span>Експрес</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="ps-lg-4">
                <div class="mb-2">
                    <span class="badge bg-purple-soft text-purple text-uppercase px-3 py-2 mb-2">@Model.Category?.Name</span>
                    <h1 class="display-5 text-white fw-bold mb-3">@Model.Name</h1>
                </div>

                <div class="price-card p-4 rounded-4 mb-4">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <span class="text-muted d-block small text-uppercase mb-2">Наемна цена</span>
                            <h2 class="text-orange fw-bold mb-0">@Model.PricePerDay.ToString("F2") лв. <span class="fs-6 text-muted fw-light">/ ден</span></h2>
                        </div>
                        <div class="text-end">
                            <span class="text-muted d-block small text-uppercase mb-3">Размер</span>
                            <span class="size-badge">@Model.Size</span>
                        </div>
                    </div>
                </div>

                <div class="row g-4 mb-5">
                    <div class="col-sm-6">
                        <h6 class="text-white text-uppercase small fw-bold mb-3">Детайли за продукта</h6>
                        <ul class="list-unstyled spec-list">
                            <li><i class="bi bi-info-circle"></i> Код: #@Model.Id.ToString("D4")</li>
                            <li><i class="bi bi-layers"></i> Материал: Висококачествен полиестер</li>
                            <li><i class="bi bi-box-seam"></i> Включва: Костюм + Аксесоари</li>
                        </ul>
                    </div>
                    <div class="col-sm-6">
                        <h6 class="text-white text-uppercase small fw-bold mb-3">Доставка и връщане</h6>
                        <ul class="list-unstyled spec-list">
                            <li><i class="bi bi-geo-alt"></i> Вземане от шоурум: 0.00 лв.</li>
                            <li><i class="bi bi-arrow-repeat"></i> Срок за връщане: До 24ч.</li>
                            <li><i class="bi bi-droplet"></i> Почистване: Включено</li>
                        </ul>
                    </div>
                </div>

                <div class="description-section mb-5 pb-4 border-bottom border-white border-opacity-10">
                    <h6 class="text-white text-uppercase small fw-bold mb-3">Описание на костюма</h6>
                    <p class="text-muted lh-lg">
                        @(string.IsNullOrEmpty(Model.Notes) ? "Този костюм е специално подбран заради автентичния си дизайн и внимание към детайла. Идеален за тематични партита, фотосесии и събития. Материята е дишаща и удобна за дълго носене." : Model.Notes)
                    </p>
                </div>

                <div class="d-flex flex-wrap gap-3">
                    <a asp-action="Index" class="btn btn-outline-spooky px-4 py-3 rounded-pill">
                        <i class="bi bi-arrow-left me-2"></i>КАТАЛОГ
                    </a>

                    @if (User.IsInRole("Administrator"))
                    {
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning-soft px-4 py-3 rounded-pill ms-md-auto">
                            <i class="bi bi-pencil-square"></i>
                        </a>
                        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger-soft px-4 py-3 rounded-pill">
                            <i class="bi bi-trash3-fill"></i>
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --theme-orange: #ff851b;
        --theme-purple: #bb86fc;
        --soft-bg: rgba(255, 255, 255, 0.03);
    }

    /* Главна снимка */
    .main-image-container {
        position: relative;
        background: #1a1a1a;
    }

    .status-overlay {
        position: absolute;
        top: 20px;
        right: -35px;
        background: #ff4136;
        color: white;
        padding: 5px 40px;
        transform: rotate(45deg);
        font-size: 10px;
        font-weight: bold;
        box-shadow: 0 5px 15px rgba(0,0,0,0.3);
    }

    /* Карти и Значки */
    .price-card {
        background: linear-gradient(145deg, rgba(255, 133, 27, 0.1) 0%, rgba(255, 255, 255, 0.02) 100%);
        border: 1px solid rgba(255, 133, 27, 0.2);
    }

    .size-badge {
        background: white;
        color: black;
        padding: 8px 15px;
        border-radius: 12px;
        font-weight: 800;
        font-size: 1.2rem;
    }

    .bg-purple-soft {
        background: rgba(187, 134, 252, 0.1);
    }

    .text-purple {
        color: var(--theme-purple);
    }

    /* Характеристики */
    .spec-list li {
        color: rgba(255,255,255,0.6);
        font-size: 0.9rem;
        margin-bottom: 12px;
        display: flex;
        align-items: center;
    }

    .spec-list i {
        color: var(--theme-orange);
        margin-right: 12px;
        font-size: 1.1rem;
    }

    .feature-box {
        background: var(--soft-bg);
        border: 1px solid rgba(255,255,255,0.05);
        padding: 15px 5px;
        border-radius: 15px;
        text-align: center;
        transition: 0.3s;
    }

        .feature-box i {
            display: block;
            color: var(--theme-orange);
            font-size: 1.4rem;
            margin-bottom: 5px;
        }

        .feature-box span {
            font-size: 0.7rem;
            text-transform: uppercase;
            color: rgba(255,255,255,0.5);
            letter-spacing: 1px;
        }

    /* Бутони */
    .btn-halloween-action {
        background: var(--theme-orange);
        color: black !important;
        font-weight: 800;
        letter-spacing: 1px;
        border: none;
        transition: 0.3s;
    }

        .btn-halloween-action:hover {
            background: #ffa04d;
            transform: translateY(-3px);
            box-shadow: 0 10px 30px rgba(255, 133, 27, 0.4) !important;
        }

    .btn-outline-spooky {
        border: 2px solid rgba(255,255,255,0.1);
        color: white;
        font-weight: 600;
    }

        .btn-outline-spooky:hover {
            border-color: var(--theme-orange);
            color: var(--theme-orange);
            background: rgba(255, 133, 27, 0.05);
        }

    /* Обновен стил за Edit бутона */
    .btn-warning-soft {
        background: rgba(255, 193, 7, 0.1);
        color: #ffc107;
        border: 1px solid rgba(255, 193, 7, 0.2);
        transition: all 0.3s ease; /* Добавено плавно преливане */
    }

        /* Обновен Hover за Edit - плътен цвят и повдигане */
        .btn-warning-soft:hover {
            background: #ffc107;
            color: black !important; /* Уверяваме се, че текстът/иконата стават черни */
            transform: translateY(-3px); /* Повдигане */
            box-shadow: 0 5px 15px rgba(255, 193, 7, 0.4); /* Светещ ефект */
        }

            /* Гарантираме, че иконата сменя цвета си при ховър */
            .btn-warning-soft:hover i {
                color: black !important;
            }

    /* Меко червено за бутона Delete */
    .btn-danger-soft {
        background: rgba(220, 53, 69, 0.1);
        color: #dc3545;
        border: 1px solid rgba(220, 53, 69, 0.2);
        transition: all 0.3s ease;
    }

        /* Hover ефект - става плътно червен с бяла икона */
        .btn-danger-soft:hover {
            background: #dc3545;
            color: white;
            transform: translateY(-3px);
            box-shadow: 0 5px 15px rgba(220, 53, 69, 0.4);
        }

            /* Уверяваме се, че иконата вътре също сменя цвета си */
            .btn-danger-soft:hover i {
                color: white !important;
            }

    .hover-zoom img {
        transition: 0.6s cubic-bezier(0.33, 1, 0.68, 1);
    }

    .hover-zoom:hover img {
        transform: scale(1.05);
    }

    .tracking-widest {
        letter-spacing: 3px;
    }

    /* Контейнерът трябва да е релативен, за да позиционираме етикета правилно */
    .main-image-container {
        position: relative;
        transition: transform 0.3s ease;
    }

    .status-overlay-spooky {
        position: absolute;
        top: 20px;
        right: -10px; /* Леко излиза извън рамката за по-интересен вид */
        background: rgba(220, 53, 69, 0.85); /* Полупрозрачно червено */
        color: white;
        padding: 8px 25px;
        font-weight: 900;
        font-size: 1.1rem;
        letter-spacing: 2px;
        text-transform: uppercase;
        transform: rotate(5deg); /* Наклон в стил "хорър плакат" */
        box-shadow: 0 0 20px rgba(220, 53, 69, 0.6); /* Светещ ефект */
        border: 1px solid rgba(255, 255, 255, 0.3);
        backdrop-filter: blur(5px); /* Стъклен ефект */
        z-index: 10;
        pointer-events: none; /* Да не пречи на кликането върху снимката */
    }
</style>