@model Costume
@{
    ViewData["Title"] = "Детайли за " + Model.Name;
}

<div class="container py-4">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" class="text-orange text-decoration-none small text-uppercase fw-bold">Каталог</a></li>
            <li class="breadcrumb-item active text-white opacity-50 small text-uppercase" aria-current="page">@Model.Name</li>
        </ol>
    </nav>

    <div class="row g-5">
        <div class="col-lg-5">
            <div class="position-sticky" style="top: 20px;">
                @if (!string.IsNullOrWhiteSpace(Model.ImagePath))
                {
                    <div class="rounded-4 overflow-hidden border border-white border-opacity-10 shadow-2xl hover-zoom main-image-container position-relative">
                        <img src="@Model.ImagePath" alt="@Model.Name" class="img-fluid w-100" />

                        @if (!Model.IsAvailable)
                        {
                            <div class="status-overlay-spooky">
                                <i class="bi bi-exclamation-triangle-fill me-1"></i> ЗАЕТ
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="rounded-4 bg-dark border border-secondary d-flex flex-column align-items-center justify-content-center text-muted" style="height: 500px;">
                        <i class="bi bi-image fs-1 opacity-25 mb-2"></i>
                        <span class="small text-uppercase tracking-widest">Няма налична снимка</span>
                    </div>
                }

                <div class="row g-2 mt-3">
                    <div class="col-4">
                        <div class="feature-box">
                            <i class="bi bi-shield-check"></i>
                            <span>Дезинфекция</span>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="feature-box">
                            <i class="bi bi-magic"></i>
                            <span>Премиум</span>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="feature-box">
                            <i class="bi bi-truck"></i>
                            <span>Експрес</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="ps-lg-4">
                <div class="mb-2">
                    <span class="badge bg-purple-soft text-purple text-uppercase px-3 py-2 mb-2">@Model.Category?.Name</span>
                    <h1 class="display-5 text-white fw-bold mb-3">@Model.Name</h1>
                </div>

                <div class="price-card p-4 rounded-4 mb-4">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <span class="text-muted d-block small text-uppercase mb-2">Наемна цена</span>
                            <h2 class="text-orange fw-bold mb-0">@Model.PricePerDay.ToString("F2") лв. <span class="fs-6 text-muted fw-light">/ ден</span></h2>
                        </div>
                        <div class="text-end">
                            <span class="text-muted d-block small text-uppercase mb-3">Размер</span>
                            <span class="size-badge">@Model.Size</span>
                        </div>
                    </div>
                </div>

                <div class="row g-4 mb-5">
                    <div class="col-sm-6">
                        <h6 class="text-white text-uppercase small fw-bold mb-3">Детайли за продукта</h6>
                        <ul class="list-unstyled spec-list">
                            <li><i class="bi bi-info-circle"></i> Код: #@Model.Id.ToString("D4")</li>
                            <li><i class="bi bi-layers"></i> Материал: Висококачествен полиестер</li>
                            <li><i class="bi bi-box-seam"></i> Включва: Костюм + Аксесоари</li>
                        </ul>
                    </div>
                    <div class="col-sm-6">
                        <h6 class="text-white text-uppercase small fw-bold mb-3">Доставка и връщане</h6>
                        <ul class="list-unstyled spec-list">
                            <li><i class="bi bi-geo-alt"></i> Вземане от шоурум: 0.00 лв.</li>
                            <li><i class="bi bi-arrow-repeat"></i> Срок за връщане: До 24ч.</li>
                            <li><i class="bi bi-droplet"></i> Почистване: Включено</li>
                        </ul>
                    </div>
                </div>

                <div class="description-section mb-5 pb-4 border-bottom border-white border-opacity-10">
                    <h6 class="text-white text-uppercase small fw-bold mb-3">Описание на костюма</h6>
                    <p class="text-muted lh-lg">
                        @(string.IsNullOrEmpty(Model.Notes) ? "Този костюм е специално подбран заради автентичния си дизайн и внимание към детайла. Идеален за тематични партита, фотосесии и събития. Материята е дишаща и удобна за дълго носене." : Model.Notes)
                    </p>
                </div>

                <div class="d-flex flex-wrap gap-3">
                    <a asp-action="Index" class="btn btn-outline-spooky px-4 py-3 rounded-pill">
                        <i class="bi bi-arrow-left me-2"></i>КАТАЛОГ
                    </a>

                    @if (User.IsInRole("Administrator"))
                    {
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning-soft px-4 py-3 rounded-pill ms-md-auto">
                            <i class="bi bi-pencil-square"></i>
                        </a>
                        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger-soft px-4 py-3 rounded-pill">
                            <i class="bi bi-trash3-fill"></i>
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

