@using CostumeRentalSystem.ViewModels
@model CostumeFormViewModel

@{
    ViewData["Title"] = "Нов костюм";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg halloween-card">
                <div class="card-header halloween-header-create text-white py-3">
                    <h4 class="mb-0"><i class="bi bi-ghost"></i> Добавяне на нов костюм</h4>
                </div>
                <div class="card-body p-4">
                    @* enctype="multipart/form-data" е критично важно за качването на файлове *@
                    <form asp-action="Create" method="post" enctype="multipart/form-data" novalidate>
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger bg-dark border-danger text-danger"></div>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold"><i class="bi bi-skull me-1"></i> Име</label>
                            <input asp-for="Name" class="form-control" placeholder="Име на костюма..." />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="CategoryId" class="form-label fw-bold">Категория</label>
                                @* Вече използваме Model.Categories вместо ViewBag *@
                                <select asp-for="CategoryId" class="form-select" asp-items="Model.Categories">
                                    <option value="">-- избор --</option>
                                </select>
                                <span asp-validation-for="CategoryId" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Size" class="form-label fw-bold">Размер</label>
                                <select asp-for="Size" class="form-select" asp-items="Html.GetEnumSelectList<CostumeRentalSystem.Data.Entities.Costume.CostumeSize>()">
                                    <option value="">-- избор --</option>
                                </select>
                                <span asp-validation-for="Size" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="PricePerDay" class="form-label fw-bold">Цена на ден</label>
                            <div class="input-group">
                                <input asp-for="PricePerDay" class="form-control" type="number" step="0.01" min="0"/>
                                <span class="input-group-text bg-dark text-orange border-secondary">лв</span>
                            </div>
                            <span asp-validation-for="PricePerDay" class="text-danger"></span>
                        </div>

                        <div class="mb-3 p-4 rounded bg-dark border border-dashed-orange text-center">
                            <label class="form-label fw-bold text-orange d-block mb-3">
                                <i class="bi bi-camera"></i> Снимка на костюма
                            </label>

                            <div class="mb-3">
                                <img id="createPreview" src="https://via.placeholder.com/200x250?text=Избери+снимка"
                                     class="img-thumbnail bg-black border-orange mb-3"
                                     style="max-height: 250px; display: block; margin: 0 auto;" />
                            </div>

                            @* asp-for="ImageFile" автоматично се свързва с IFormFile в модела *@
                            <input asp-for="ImageFile" type="file" class="form-control" id="imageFile" accept="image/*" onchange="previewCreateImage(this)" />
                            <span asp-validation-for="ImageFile" class="text-danger small"></span>
                            <small class="text-muted">Поддържани формати: JPG, PNG, WebP</small>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Notes" class="form-label fw-bold"><i class="bi bi-sticky me-1"></i> Бележки / Описание</label>
                            <textarea asp-for="Notes" class="form-control bg-dark text-white border-secondary"
                                      rows="3" placeholder="Добавете информация за аксесоари, състояние или специфики..."></textarea>
                            <span asp-validation-for="Notes" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-between pt-3 border-top border-secondary">
                            <a asp-action="Index" class="btn btn-outline-light">Назад</a>
                            <button type="submit" class="btn btn-spooky-orange px-5"><i class="bi bi-check2-circle me-2"></i>Запази </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function previewCreateImage(input) {
            const preview = document.getElementById('createPreview');
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    preview.src = e.target.result;
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}