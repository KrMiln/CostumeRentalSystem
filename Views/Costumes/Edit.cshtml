@model CostumeRentalSystem.Models.Costume
@{
    ViewData["Title"] = "Редакция на костюм";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg halloween-card border-purple">
                <div class="card-header halloween-header-edit text-white py-3">
                    <h4 class="mb-0"><i class="bi bi-pencil-square"></i> Редакция на костюм</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post" enctype="multipart/form-data">
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="ImageUrl" />

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold"><i class="bi bi-skull me-1"></i> Име</label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="CategoryId" class="form-label fw-bold">Категория</label>
                                <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId"></select>
                                <span asp-validation-for="CategoryId" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Size" class="form-label fw-bold">Размер</label>
                                <select asp-for="Size" class="form-select" asp-items="Html.GetEnumSelectList<CostumeRentalSystem.Models.Costume.CostumeSize>()"></select>
                                <span asp-validation-for="Size" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="PricePerDay" class="form-label fw-bold">Цена на ден</label>
                            <div class="input-group">
                                <input asp-for="PricePerDay" class="form-control" type="number" step="0.01" />
                                <span class="input-group-text bg-dark text-orange border-secondary">лв</span>
                            </div>
                            <span asp-validation-for="PricePerDay" class="text-danger"></span>
                        </div>

                        <div class="mb-3 p-3 rounded bg-dark border border-purple">
                            <div class="row align-items-center text-center">
                                <div class="col-md-5">
                                    <p class="small text-muted mb-2" id="previewLabel">Текущо изображение:</p>
                                    <img id="editPreview" src="@Model.ImageUrl" class="img-thumbnail bg-black border-purple" style="max-height: 180px; width: auto;" />
                                </div>
                                <div class="col-md-7 mt-3 mt-md-0 border-start border-secondary">
                                    <label class="form-label fw-bold text-purple"><i class="bi bi-cloud-arrow-up"></i> Смени изображението</label>
                                    <input type="file" name="imageFile" class="form-control" accept="image/*" onchange="handleImagePreview(this, 'editPreview', 'previewLabel')" />
                                    <small class="text-muted d-block mt-2">Качете нов файл, за да актуализирате визията.</small>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3 form-check form-switch">
                            <input asp-for="IsAvailable" class="form-check-input" type="checkbox" />
                            <label asp-for="IsAvailable" class="form-check-label">В наличност</label>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Notes" class="form-label fw-bold">Бележки</label>
                            <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                        </div>

                        <div class="d-flex justify-content-between pt-3 border-top border-secondary">
                            <a asp-action="Index" class="btn btn-outline-light"><i class="bi bi-arrow-left"></i> Назад към списъка</a>
                            <button type="submit" class="btn btn-spooky-purple px-4">
                                <i class="bi bi-save"></i> Запази промените
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function handleImagePreview(input, imgElementId, labelId) {
            const previewImage = document.getElementById(imgElementId);
            const label = document.getElementById(labelId);

            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    previewImage.src = e.target.result;
                    if (label) {
                        label.innerText = "Ново избрано изображение:";
                        label.style.color = "#ff7518"; // Оранжев цвят за внимание
                    }
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}