@model ClientIndexViewModel
@{
    ViewData["Title"] = "Клиенти";
}

<div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom border-secondary">
    <div>
        <h1 class="text-white fw-bold mb-0">
            <i class="bi bi-people-fill me-2 text-orange"></i>Клиенти
        </h1>
        <p class="text-muted mb-0">Управление на клиентската база и контактна информация</p>
    </div>
    <a asp-action="Create" class="btn btn-ghost-orange fw-bold px-4">
        <i class="bi bi-person-plus-fill me-2"></i>Нов клиент
    </a>
</div>

<div class="card mb-4 border-0 spooky-card shadow">
    <div class="card-header border-bottom border-secondary border-opacity-25 bg-transparent py-3">
        <h6 class="m-0 fw-bold text-orange"><i class="bi bi-filter"></i> Филтриране</h6>
    </div>

    <div class="card-body">
        <form method="get" asp-action="Index" class="row g-3">
            <div class="col-md-4">
                <label class="form-label text-muted small fw-bold text-uppercase">Име на клиент</label>
                <input type="text" name="searchName" value="@Model.SearchName"
                       class="form-control bg-dark text-white border-secondary shadow-none" placeholder="Търсене..." />
            </div>

            <div class="col-md-3">
                <label class="form-label text-muted small fw-bold text-uppercase">Телефон</label>
                <input type="text" name="searchPhone" value="@Model.SearchPhone"
                       class="form-control bg-dark text-white border-secondary shadow-none" placeholder="Търсене..." />
            </div>

            <div class="col-md-3">
                <label class="form-label text-muted small fw-bold text-uppercase">Имейл</label>
                <input type="text" name="searchEmail" value="@Model.SearchEmail"
                       class="form-control bg-dark text-white border-secondary shadow-none" placeholder="Търсене..." />
            </div>

            <div class="col-md-2 d-flex gap-2 align-items-end">
                <button type="submit" class="btn btn-ghost-white px-4 text-nowrap">
                    <i class="bi bi-search me-2"></i>Приложи
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-clockwise"></i>
                </a>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 spooky-card shadow-lg overflow-hidden">
    <div class="table-responsive">
        <table class="table table-dark table-hover align-middle mb-0">
            <thead>
                <tr class="text-uppercase small text-muted border-bottom border-secondary">
                    <th class="ps-4 py-3">Клиент</th>
                    <th class="py-3">Контакти</th>
                    <th class="py-3">Бележки</th>
                    <th class="text-end pe-4 py-3">Действия</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Clients.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-5 text-muted italic">
                            <i class="bi bi-exclamation-circle me-2"></i>Няма намерени клиенти по тези критерии.
                        </td>
                    </tr>
                }
                @foreach (var item in Model.Clients)
                {
                    <tr class="border-bottom border-secondary-subtle">
                        <td class="ps-4">
                            <div class="d-flex align-items-center">
                                <div class="avatar-circle me-3">
                                    @(string.IsNullOrEmpty(item.Name) ? "?" : item.Name.Substring(0, 1).ToUpper())
                                </div>
                                <span class="fw-bold text-light">@item.Name</span>
                            </div>
                        </td>
                        <td>
                            <div class="small">
                                <div class="mb-1"><i class="bi bi-telephone text-orange me-2"></i>@item.PhoneNumber</div>
                                <div><i class="bi bi-envelope text-info me-2"></i><span class="text-muted">@item.Email</span></div>
                            </div>
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.Notes))
                            {
                                <span class="text-truncate d-inline-block cursor-help text-muted"
                                      style="max-width: 200px; border-bottom: 1px dashed #666;"
                                      data-bs-toggle="tooltip"
                                      title="@item.Notes">
                                    @item.Notes
                                </span>
                            }
                            else
                            {
                                <span class="text-muted small">-</span>
                            }
                        </td>
                        <td class="text-end pe-4">
                            <div class="btn-group gap-1">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info" title="Редактирай">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-light" title="Детайли">
                                    <i class="bi bi-eye"></i>
                                </a>
                                @if (User.IsInRole("Administrator"))
                                {
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="Изтрий">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="mt-4">
    @* Използваме модела от обекта, вместо ViewBag *@
    <partial name="_PaginationPartial" model="Model.Pagination" />
</div>

@section Scripts {
    <script>
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl)
        })
    </script>
}

<style>
    /* Запазваме твоя страхотен стил... */
    :root {
        --halloween-orange: #ff851b;
        --witch-purple: #8e44ad;
    }

    .text-orange {
        color: var(--halloween-orange) !important;
    }

    .btn-ghost-orange {
        background: transparent;
        color: var(--halloween-orange) !important;
        border: 2px solid var(--halloween-orange);
        border-radius: 0px;
        text-transform: uppercase;
        letter-spacing: 2px;
        position: relative;
        transition: all 0.3s ease-in-out;
        animation: neon-pulse 2s infinite alternate;
    }

        .btn-ghost-orange:hover {
            background: var(--halloween-orange);
            color: #000 !important;
            box-shadow: 0 0 20px var(--halloween-orange), 0 0 40px var(--halloween-orange);
            transform: scale(1.05);
        }

    /* Transparent to White/Black Hover Style */
    .btn-ghost-white {
        background: transparent;
        color: #ffffff;
        border: 1px solid rgba(255, 255, 255, 0.4);
        font-weight: 600;
        transition: all 0.25s ease-in-out;
        border-radius: 8px; /* Matches your card design */
    }

        .btn-ghost-white:hover {
            background: #ffffff !important; /* Becomes solid white */
            color: #000000 !important; /* Text becomes black */
            border-color: #ffffff;
            transform: translateY(-1px);
            box-shadow: 0 5px 15px rgba(255, 255, 255, 0.2);
        }

        .btn-ghost-white:active {
            background: #e0e0e0 !important; /* Slightly grey when pressed */
            transform: translateY(0);
        }

        /* Optional: Make the icon change color too */
        .btn-ghost-white:hover i {
            color: #000000;
        }

    @@keyframes neon-pulse {
        from {
            box-shadow: 0 0 5px rgba(255, 133, 27, 0.4);
        }

        to {
            box-shadow: 0 0 15px rgba(255, 133, 27, 0.8);
        }
    }

    .spooky-card {
        background: rgba(255, 255, 255, 0.03) !important;
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        border-radius: 15px;
    }

    .avatar-circle {
        width: 38px;
        height: 38px;
        background: linear-gradient(135deg, #6f42c1, var(--witch-purple));
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        box-shadow: 0 0 12px rgba(111, 66, 193, 0.4);
    }

    .table-hover tbody tr:hover {
        background-color: rgba(255, 255, 255, 0.05) !important;
    }

    .cursor-help {
        cursor: help;
    }
</style>