@model CostumeRentalSystem.Models.Client
@{
    ViewData["Title"] = "Детайли за клиент";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-0 spooky-card shadow-lg overflow-hidden">
                <div class="card-header bg-dark border-bottom border-orange py-5 text-center position-relative">
                    <div class="details-avatar mx-auto mb-3">
                        @Model.Name.Substring(0, 1).ToUpper()
                    </div>
                    <h2 class="text-white fw-bold">@Model.Name</h2>
                    <span class="badge rounded-pill bg-orange text-dark px-3">КЛИЕНТ #@Model.Id</span>
                </div>

                <div class="card-body p-5">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <h5 class="text-orange mb-3 border-bottom border-secondary pb-2">КОНТАКТИ</h5>
                            <p class="mb-2 text-muted small text-uppercase">Телефон</p>
                            <p class="text-white fs-5"><i class="bi bi-telephone me-2 text-orange"></i>@Model.PhoneNumber</p>

                            <p class="mb-2 text-muted small text-uppercase mt-4">Имейл</p>
                            <p class="text-white fs-5"><i class="bi bi-envelope me-2 text-orange"></i>@Model.Email</p>
                        </div>

                        <div class="col-md-6">
                            <h5 class="text-orange mb-3 border-bottom border-secondary pb-2">ИНФОРМАЦИЯ</h5>
                            <p class="mb-2 text-muted small text-uppercase">Бележки към архива</p>
                            <div class="p-3 bg-black bg-opacity-50 border border-secondary text-muted rounded min-vh-10">
                                @(string.IsNullOrEmpty(Model.Notes) ? "Няма налични бележки за този клиент." : Model.Notes)
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-center gap-3 mt-5">
                        <a asp-action="Index" class="btn btn-outline-secondary px-4 rounded-0">
                            <i class="bi bi-arrow-left"></i> НАЗАД
                        </a>
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-ghost-orange px-5">
                            <i class="bi bi-pencil"></i> РЕДАКТИРАЙ
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .text-orange {
        color: #ff851b !important;
    }

    .bg-orange {
        background-color: #ff851b !important;
    }

    .border-orange {
        border-color: #ff851b !important;
    }

    .spooky-card {
        background: rgba(20, 20, 20, 0.95);
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        border-radius: 0px;
    }

    .spooky-input {
        background-color: #1a1a1a !important;
        border: 1px solid #333 !important;
        color: white !important;
        border-radius: 0px;
    }

        .spooky-input:focus {
            border-color: #ff851b !important;
            box-shadow: 0 0 10px rgba(255, 133, 27, 0.2);
        }

    .details-avatar {
        width: 100px;
        height: 100px;
        background: linear-gradient(135deg, #ff851b, #8e44ad);
        color: black;
        font-size: 3rem;
        font-weight: bold;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 0 30px rgba(255, 133, 27, 0.4);
        border: 4px solid #121212;
    }

    .btn-ghost-orange {
        background: transparent;
        color: #ff851b !important;
        border: 2px solid #ff851b;
        border-radius: 0px;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: 0.3s;
    }

        .btn-ghost-orange:hover {
            background: #ff851b;
            color: #000 !important;
            box-shadow: 0 0 15px #ff851b;
        }
</style>