@using CostumeRentalSystem.ViewModels.Clients
@model ClientFormViewModel
@{
    ViewData["Title"] = "Нов клиент";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow-lg border-0 spooky-create-card animate__animated animate__fadeInUp">
                <div class="card-header border-bottom border-secondary border-opacity-25 bg-transparent py-4 text-center">
                    <h2 class="text-orange fw-bold mb-0">
                        <i class="bi bi-person-plus-fill me-2"></i>РЕГИСТРАЦИЯ НА КЛИЕНТ
                    </h2>
                    <p class="text-muted small text-uppercase letter-spacing-1 mt-2">Въведете личните данни в архива</p>
                </div>

                <div class="card-body p-5">
                    <form asp-action="Create" method="post">
                        @* Скрит Id за редакция, въпреки че тук е Create, е добра практика да го има в общата форма *@
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="UserId" />

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger bg-dark border-danger text-danger small"></div>

                        <div class="mb-4">
                            <label asp-for="Name" class="form-label text-light fw-bold">
                                <i class="bi bi-person me-1 text-orange"></i> @Html.DisplayNameFor(m => m.Name)
                            </label>
                            <input asp-for="Name" class="form-control spooky-input" placeholder="Иван Иванов..." />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label asp-for="Phone" class="form-label text-light fw-bold">
                                    <i class="bi bi-telephone me-1 text-orange"></i> @Html.DisplayNameFor(m => m.Phone)
                                </label>
                                <input asp-for="Phone" class="form-control spooky-input" placeholder="08X XXX XXXX" />
                                <span asp-validation-for="Phone" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-4">
                                <label asp-for="Email" class="form-label text-light fw-bold">
                                    <i class="bi bi-envelope me-1 text-orange"></i> @Html.DisplayNameFor(m => m.Email)
                                </label>
                                <input asp-for="Email" class="form-control spooky-input" placeholder="example@mail.com" />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Notes" class="form-label text-light fw-bold">
                                <i class="bi bi-journal-text me-1 text-orange"></i> @Html.DisplayNameFor(m => m.Notes)
                            </label>
                            <textarea asp-for="Notes" class="form-control spooky-input" rows="4"
                                      placeholder="Специфични изисквания, мерки или история на лоялност..."></textarea>
                            <span asp-validation-for="Notes" class="text-danger small"></span>
                        </div>

                        <hr class="border-secondary opacity-25 my-4">

                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Index" class="btn btn-link text-muted text-decoration-none hover-white">
                                <i class="bi bi-arrow-left me-1"></i> Назад
                            </a>
                            <button type="submit" class="btn btn-ghost-orange px-5 py-2 fw-bold">
                                <i class="bi bi-check2-circle me-2"></i>ЗАПАЗИ
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    /* Твоят оригинален стил остава непроменен */
    :root {
        --halloween-orange: #ff851b;
        --dark-bg: #121212;
    }

    .spooky-create-card {
        background: rgba(20, 20, 20, 0.95);
        backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 133, 27, 0.2) !important;
        border-radius: 0px;
    }

    .spooky-input {
        background-color: #1a1a1a !important;
        border: 1px solid #333 !important;
        color: white !important;
        border-radius: 0px;
        padding: 12px 15px;
        transition: all 0.3s ease;
    }

        .spooky-input:focus {
            border-color: var(--halloween-orange) !important;
            box-shadow: 0 0 10px rgba(255, 133, 27, 0.2);
            background-color: #222 !important;
        }

    .text-orange {
        color: var(--halloween-orange) !important;
    }

    .letter-spacing-1 {
        letter-spacing: 1px;
    }

    .btn-ghost-orange {
        background: transparent;
        color: var(--halloween-orange) !important;
        border: 2px solid var(--halloween-orange);
        border-radius: 0px;
        text-transform: uppercase;
        letter-spacing: 2px;
        transition: all 0.3s ease-in-out;
    }

        .btn-ghost-orange:hover {
            background: var(--halloween-orange);
            color: #000 !important;
            box-shadow: 0 0 20px var(--halloween-orange);
        }

    .hover-white:hover {
        color: white !important;
    }

    .animate__fadeInUp {
        animation: fadeInUp 0.6s ease-out;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>