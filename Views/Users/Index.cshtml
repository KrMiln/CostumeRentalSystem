@using CostumeRentalSystem.Controllers
@model IEnumerable<UserWithRolesViewModel>
@{
    ViewData["Title"] = "Управление на потребители";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-end mb-5">
        <div>
            <h6 class="text-orange text-uppercase tracking-widest fw-bold mb-1" style="font-size: 0.7rem; opacity: 0.8;">Администрация</h6>
            <h2 class="text-white fw-light mb-0">Потребителски <span class="fw-bold">Профили</span></h2>
        </div>
        <div class="stats-box d-flex gap-4">
            <div class="stat">
                <span class="text-muted d-block small uppercase">Общо потребители</span>
                <span class="text-white fw-bold fs-5">@Model.Count()</span>
            </div>
        </div>
    </div>

    <div class="glass-panel overflow-hidden">
        <div class="table-responsive">
            <table class="table table-dark-custom m-0">
                <thead>
                    <tr>
                        <th class="ps-4">Потребител</th>
                        <th>Текуща роля</th>
                        <th>Промяна на права</th>
                        <th class="text-end pe-4">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="ps-4 py-3">
                                <div class="d-flex align-items-center">
                                    <div class="user-avatar me-3">
                                        @user.Email.Substring(0, 1).ToUpper()
                                    </div>
                                    <div>
                                        <div class="text-white fw-bold">@user.Email</div>
                                        <div class="text-muted small">ID: @user.UserId.Substring(0, 8)...</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                @foreach (var role in user.Roles)
                                {
                                    <span class="badge role-badge @(role == "Administrator" ? "bg-orange" : "bg-grey")">
                                        @role
                                    </span>
                                }
                            </td>
                            <td>
                                @if (!user.Roles.Contains("Administrator"))
                                {
                                    <form asp-action="SetRole" method="post" class="d-flex gap-2 align-items-center">
                                        <input type="hidden" name="userId" value="@user.UserId" />
                                        <select name="roleName" class="form-select-sm studio-select-sm">
                                            <option value="Client">Client</option>
                                            <option value="Employee">Employee</option>
                                        </select>
                                        <button type="submit" class="btn btn-sm btn-outline-warning rounded-pill">
                                            Обнови
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-muted small italic">Системен профил</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                @if (!user.Roles.Contains("Administrator"))
                                {
                                    <form asp-action="Delete" method="post" onsubmit="return confirm('Наистина ли искате да изтриете този потребител?');">
                                        <input type="hidden" name="userId" value="@user.UserId" />
                                        <button type="submit" class="btn-delete-icon">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    :root {
        --theme-orange: #ff851b;
        --glass-bg: rgba(255, 255, 255, 0.02);
        --glass-border: rgba(255, 255, 255, 0.08);
    }

    /* Glass Panel Setup */
    .glass-panel {
        background: var(--glass-bg);
        backdrop-filter: blur(15px);
        border: 1px solid var(--glass-border);
        border-radius: 20px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.3);
    }

    /* Table Styling */
    .table-dark-custom {
        --bs-table-bg: transparent;
        --bs-table-color: #ddd;
        border-collapse: separate;
        border-spacing: 0;
    }

        .table-dark-custom thead th {
            background: rgba(255,255,255,0.03);
            color: var(--theme-orange);
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 1px;
            border-bottom: 1px solid var(--glass-border);
            padding: 15px;
        }

        .table-dark-custom tbody tr {
            border-bottom: 1px solid rgba(255,255,255,0.03);
            transition: background 0.3s;
        }

            .table-dark-custom tbody tr:hover {
                background: rgba(255,255,255,0.02);
            }

    /* User Avatar */
    .user-avatar {
        width: 38px;
        height: 38px;
        background: linear-gradient(135deg, var(--theme-orange), #ff4500);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: black;
        font-weight: 900;
    }

    /* Badges */
    .role-badge {
        padding: 5px 12px;
        border-radius: 6px;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
    }

    .bg-orange {
        background: var(--theme-orange) !important;
        color: black;
    }

    .bg-grey {
        background: rgba(255,255,255,0.1) !important;
        color: white;
    }

    /* Custom Select & Buttons */
    .studio-select-sm {
        background: #000;
        border: 1px solid var(--glass-border);
        color: white;
        font-size: 0.8rem;
        border-radius: 5px;
        padding: 2px 8px;
        outline: none;
    }

    .btn-delete-icon {
        background: rgba(255,77,77,0.1);
        border: none;
        color: #ff4d4d;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        transition: 0.3s;
    }

        .btn-delete-icon:hover {
            background: #ff4d4d;
            color: white;
            transform: scale(1.1);
        }

    .tracking-widest {
        letter-spacing: 3px;
    }

    .uppercase {
        text-transform: uppercase;
    }

    .italic {
        font-style: italic;
    }
</style>