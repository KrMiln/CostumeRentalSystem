@using CostumeRentalSystem.ViewModels.Users
@model UserIndexViewModel

@{
    ViewData["Title"] = "Управление на потребители";
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
}

<div class="container py-5">
    @* --- Header Section --- *@
    <div class="row align-items-end mb-4 g-4">
        <div class="col-lg-8">
            <h1 class="text-white fw-light mb-0" style="font-size: 2.5rem;">Системни <span class="fw-bold text-orange">Потребители</span></h1>
        </div>
        <div class="col-lg-4 d-flex justify-content-lg-end">
            <div class="glass-stats px-4 py-3 shadow-lg">
                <div class="text-end">
                    <span class="text-muted d-block small fw-bold mb-1">ОБЩО АКАУНТИ</span>
                    <div class="d-flex align-items-center justify-content-end">
                        @* Използваме директното свойство от модела *@
                        <span class="text-white fw-bold fs-4">@Model.TotalUsersCount</span>
                        <i class="bi bi-people text-orange ms-2" style="font-size: 1.6rem;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* --- Filter Section --- *@
    <div class="glass-panel p-4 mb-4 border-orange-soft">
        <div class="border-bottom border-secondary border-opacity-25 bg-transparent pb-3 mb-4">
            <h6 class="m-0 fw-bold text-orange text-uppercase" style="letter-spacing: 1px;">
                <i class="bi bi-filter me-2"></i>Филтриране
            </h6>
        </div>

        <form method="get" asp-action="Index" class="row g-3 align-items-end">
            <div class="col-md-5">
                <label class="form-label text-orange small fw-bold text-uppercase mb-2" style="letter-spacing: 1px;">Потребителско име или имейл</label>
                <div class="input-group">
                    <span class="input-group-text bg-black border-secondary text-muted"><i class="bi bi-search"></i></span>
                    <input type="text" asp-for="SearchTerm" class="form-control admin-input" placeholder="Търсене...">
                </div>
            </div>

            <div class="col-md-4">
                <label class="form-label text-orange small fw-bold text-uppercase mb-2" style="letter-spacing: 1px;">Роля</label>
                <select asp-for="RoleFilter" class="form-select admin-select">
                    <option value="">-- Всички роли --</option>
                    <option value="Administrator">Администратор</option>
                    <option value="Employee">Служител</option>
                    <option value="Client">Клиент</option>
                </select>
            </div>

            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-orange fw-bold w-100 py-2">
                    <i class="bi bi-search me-2"></i>Приложи
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary py-2 px-3 d-flex align-items-center justify-content-center" title="Изчисти филтри">
                    <i class="bi bi-arrow-counterclockwise"></i>
                </a>
            </div>
        </form>
    </div>

    @* --- Table Container --- *@
    <div class="glass-panel shadow-2xl overflow-hidden">
        <div class="table-responsive">
            <table class="table table-dark-custom m-0 align-middle">
                <thead>
                    <tr>
                        <th class="ps-4">Потребителско име</th>
                        <th>Имейл адрес</th>
                        <th>Роля</th>
                        <th>Управление</th>
                        <th class="text-center pe-4">Изтриване</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Users.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted italic">
                                <i class="bi bi-exclamation-circle me-2"></i>Няма намерени потребители по тези критерии.
                            </td>
                        </tr>
                    }
                    @foreach (var user in Model.Users)
                    {
                        var isMe = user.UserId == currentUserId;
                        var isAdmin = user.Role == "Administrator";

                        <tr class="@(isMe ? "me-row" : "")">
                            <td class="ps-4 py-4">
                                <div class="d-flex align-items-center">
                                    <div class="avatar-container me-3 position-relative">
                                        <div class="user-avatar-lg @(isAdmin ? "border-orange" : "")">
                                            @user.Username[0].ToString().ToUpper()
                                        </div>
                                        @if (isAdmin)
                                        {
                                            <div class="status-dot-admin" title="Администратор"></div>
                                        }
                                    </div>
                                    <div class="text-white fw-bold fs-5 mb-0">@user.Username</div>
                                </div>
                            </td>
                            <td>
                                <div class="text-muted fw-medium">
                                    <i class="bi bi-envelope-fill me-2 opacity-50 text-orange"></i>@user.Email
                                </div>
                            </td>
                            <td>
                                <span class="role-pill @(isAdmin ? "role-admin" : "role-user")">
                                    <i class="bi @(isAdmin ? "bi-shield-shaded" : "bi-person") me-1"></i>
                                    @* Тук можеш да използваш директно user.Role или твоя switch *@
                                    @(user.Role == "Administrator" ? "Администратор" : user.Role == "Employee" ? "Служител" : user.Role == "Client" ? "Клиент" : "Няма роля")
                                </span>
                            </td>
                            <td>
                                @if (!isAdmin && !isMe)
                                {
                                    <form asp-action="SetRole" method="post" class="role-update-form">
                                        <input type="hidden" name="userId" value="@user.UserId" />
                                        <div class="input-group input-group-sm" style="max-width: 200px;">
                                            <select name="roleName" class="form-select admin-select" required>
                                                <option value="" disabled selected>Промени роля</option>
                                                <option value="Client">Клиент</option>
                                                <option value="Employee">Служител</option>
                                            </select>
                                            <button type="submit" class="btn btn-orange-sm">
                                                <i class="bi bi-save2"></i>
                                            </button>
                                        </div>
                                    </form>
                                }
                                else
                                {
                                    <span class="badge bg-dark border border-secondary text-muted small px-3">
                                        <i class="bi bi-lock-fill me-1"></i>Защитен профил
                                    </span>
                                }
                            </td>
                            <td class="pe-4 text-center">
                                @if (!isAdmin && !isMe)
                                {
                                    <form asp-action="Delete" method="post" onsubmit="return confirm('Наистина ли искате да изтриете този потребител?');">
                                        <input type="hidden" name="userId" value="@user.UserId" />
                                        <button type="submit" class="btn-modern-delete"><i class="bi bi-trash3"></i></button>
                                    </form>
                                }
                                else
                                {
                                    <i class="bi bi-shield-lock-fill text-muted opacity-25 fs-4"></i>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* --- Pagination --- *@
    <div class="mt-5 d-flex justify-content-center">
        <partial name="_PaginationPartial" model="Model.Pagination" />
    </div>
</div>

<style>
    :root {
        --theme-orange: #ff851b;
        --deep-dark: #0a0a0a;
        --glass-white: rgba(255, 255, 255, 0.05);
    }

    body {
        font-size: 1.05rem;
        background-color: #050505;
        color: white;
    }

    .glass-panel {
        background: rgba(18, 18, 18, 0.8);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 20px;
    }

    .border-orange-soft {
        border: 1px solid rgba(255, 133, 27, 0.2);
    }

    /* Inputs */
    .admin-input, .admin-select {
        background-color: #000 !important;
        color: #fff !important;
        border: 1px solid #333 !important;
        padding: 0.6rem 1rem;
    }

        .admin-input:focus, .admin-select:focus {
            border-color: var(--theme-orange) !important;
            box-shadow: 0 0 10px rgba(255, 133, 27, 0.1);
        }

    .btn-orange {
        background: var(--theme-orange);
        color: #000;
        border: none;
        transition: all 0.2s ease; /* Snappier transition */
    }

        /* Change this from background: #fff to a hover effect that stays orange */
        .btn-orange:hover {
            background: #ff9d47; /* A slightly lighter orange instead of white */
            color: #000;
            box-shadow: 0 4px 15px rgba(255, 133, 27, 0.3);
        }

        /* This handles the "pressed" state */
        .btn-orange:active {
            background: #e67616 !important; /* Darker orange when clicked */
            transform: translateY(0);
        }

    /* Small fix for the save button inside the table as well */
    .btn-orange-sm {
        background: var(--theme-orange);
        color: #000;
        border: none;
        padding: 0 10px;
        transition: 0.2s;
    }

        .btn-orange-sm:hover {
            background: #ff9d47;
            color: #000;
        }

    .btn-outline-secondary {
        border: 1px solid #333;
        color: #888;
    }

        .btn-outline-secondary:hover {
            background: #222;
            color: #fff;
        }

    /* Table & Components */
    .table-dark-custom thead th {
        color: var(--theme-orange);
        font-weight: 700;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        padding: 20px 15px;
        border: none;
    }

    .user-avatar-lg {
        width: 46px;
        height: 46px;
        background: linear-gradient(135deg, #1a1a1a, #000);
        border: 2px solid rgba(255,255,255,0.15);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--theme-orange);
        font-weight: 800;
    }

    .status-dot-admin {
        position: absolute;
        top: -4px;
        right: -4px;
        width: 14px;
        height: 14px;
        background: var(--theme-orange);
        border: 2px solid #111;
        border-radius: 50%;
    }

    .role-pill {
        padding: 5px 12px;
        border-radius: 8px;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
    }

    .role-admin {
        background: rgba(255, 133, 27, 0.2);
        color: var(--theme-orange);
        border: 1px solid var(--theme-orange);
    }

    .role-user {
        background: rgba(255, 255, 255, 0.08);
        color: #ccc;
    }

    .btn-modern-delete {
        background: transparent;
        color: #ff4d4d;
        border: 1px solid rgba(255, 77, 77, 0.3);
        width: 38px;
        height: 38px;
        border-radius: 10px;
        transition: 0.3s;
    }

        .btn-modern-delete:hover {
            background: #ff4d4d;
            color: #fff;
        }

    .me-row {
        border-left: 4px solid var(--theme-orange);
        background: rgba(255, 133, 27, 0.03);
    }

    .text-muted-dark {
        color: #555;
    }

</style>