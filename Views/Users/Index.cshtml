@model IEnumerable<CostumeRentalSystem.Controllers.UserWithRolesViewModel>
@{
    ViewData["Title"] = "Потребители";
}

<h1 class="mb-3">Управление на потребители</h1>

<table class="table table-striped table-hover shadow-sm rounded bg-white">
    <thead>
        <tr>
            <th>Имейл</th>
            <th>Роли</th>
            <th class="text-end">Действия</th>
        </tr>
    </thead>
    <tbody>
@foreach (var user in Model)
{
        <tr>
            <td>@user.Email</td>
            <td>
                @if (user.Roles.Any())
                {
                    @string.Join(", ", user.Roles)
                }
                else
                {
                    <span class="text-muted">Няма роля</span>
                }
            </td>
            <td class="text-end">
                @if (!user.Roles.Contains("Administrator"))
                {
                    <form asp-action="SetRole" method="post" class="d-inline">
                        <input type="hidden" name="userId" value="@user.UserId" />
                        <input type="hidden" name="roleName" value="Employee" />
                        <button type="submit" class="btn btn-sm btn-outline-primary">Маркирай като служител</button>
                    </form>
                    <form asp-action="SetRole" method="post" class="d-inline ms-1">
                        <input type="hidden" name="userId" value="@user.UserId" />
                        <input type="hidden" name="roleName" value="Client" />
                        <button type="submit" class="btn btn-sm btn-outline-success">Маркирай като клиент</button>
                    </form>
                    <form asp-action="Delete" method="post" class="d-inline ms-1" onsubmit="return confirm('Сигурни ли сте, че искате да изтриете този потребител?');">
                        <input type="hidden" name="userId" value="@user.UserId" />
                        <button type="submit" class="btn btn-sm btn-danger">Изтриване</button>
                    </form>
                }
                else
                {
                    <span class="badge bg-secondary">Администратор</span>
                }
            </td>
        </tr>
}
    </tbody>
</table>

